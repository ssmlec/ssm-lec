in setup.</div>","provider.flow.tier2.card_1.content.sentence_1":"Log in to your {providerName} account","provider.flow.cta.sentence_1":"If your domain is not verified in 5 minutes:","provider.flow.table.row.cta":"Auto added","provider.flow.godaddy.card_1.cta.sentence_2":"Log in to your {providerName} account, open the top right menu, and choose <bold>\u201cMy Products\u201d</bold> under the <bold>\u201cAccount\u201d</bold> section","provider.flow.table.column_title.name_host":"Name/Host","provider.flow.tier2.card_3.content.sentence_1":"Once you\u2019ve added your records at Wix, head back to {providerName}","intro.providers.other.value":"Other","error.message.subtitle":"Try waiting a few more moments and then refresh the page.","provider.flow.continue.button":"Continue","provider.flow.other.card_3.cta":"<bold>Note:</bold> Paste all the record details from {providerName} like <bold>Name/Host, Value, TTL, Priority,</bold> etc.","provider.flow.google_workspace.card_1.tooltip":"\u201cVerify domain\u201d might appear as \u201cProtect your domain.\u201d","provider.flow.google_workspace.card_2.content.sentence_2":"Copy only the <bold>TXT value</bold> and come back here","provider.flow.godaddy.dropdown.placeholder":"MS=msxxxxxxxx or Dxxxxxxx","provider.flow.other.cta.sentence_2":"Wait a few minutes and then try checking if the domain was successfully connected","provider.flow.microsoft_365.card_2.content.cta":"You\u2019ll need to add your DNS records from {providerName} to your domain settings at Wix. \\n<bold>Some of the records were already added automatically:</bold>","provider.flow.tier2.card_2.content.sentence_1":"You\u2019ll need to add your DNS records from {providerName} to your domain settings at Wix. \\nSome of the records were already added automatically:","provider.flow.godaddy.card_3.content.sentence_2":"To finish setup, hit <bold>\u201cCheck My Settings\u201d</bold> at the bottom of the page. You\u2019ll know you\u2019re done with setup once you get a message from GoDaddy that <bold>\u201cYour email\u2019s ready to use!\u201d</bold>","provider.flow.tier2.card_1.content.sentence_4":"Find the DNS records provided by {providerName} (e.g. <bold>MX, TXT, CNAME</bold>, etc.) <div>Once you get them, keep this page open and come back here.</div>","provider.flow.other.card_3.content.sentence_3":"Go to your domain\'s <textbutton>Manage DNS Records</textbutton> page at Wix","provider.flow.tier2.cta.sentence_2":"Wait a few minutes and then try verifying your domain again","provider.flow.google_workspace.card_1.content.sentence_1":"Head to the <textbutton>Google admin console</textbutton> and log in to your dashboard","provider.flow.google_workspace.card_2.save_failed.cta":"Try to save your value again or refresh the page","provider.flow.table.column_title.value":"Value","provider.flow.godaddy.card_2.content.sentence_2":"At this step, copy only the first <bold>\u201cTXT value\u201d</bold> and come back here"}')},7747:(e,t,o)=>{var n=o(21960),r=Object.prototype.hasOwnProperty;e.exports=function(e){var t=this.__data__;if(n){var o=t[e];return"__lodash_hash_undefined__"===o?void 0:o}return r.call(t,e)?t[e]:void 0}},7764:(e,t,o)=>{"use strict";o.d(t,{X:()=>n,ub:()=>r,vO:()=>a});const n={fadeStyles:"fadeStyles",moveStyles:"moveStyles",toggleStyles:"toggleStyles",scaleStyles:"scaleStyles",transition:"transition"},r={standardEasing:"cubic-bezier(0.4, 0.0, 0.2, 1)",enterEasing:"cubic-bezier(0.0, 0.0, 0.2, 1)",exitEasing:"cubic-bezier(0.4, 0.0, 1, 1)"},a={short:100,medium:150,long:200,fast01:100,fast02:150,medium01:200,medium02:300,slow01:450,slow02:600}},7801:(e,t,o)=>{"use strict";o.d(t,{O:()=>B});var n=o(41594),r=o.n(n),a=o(88259),i=o(51444),s=o.n(i),l=o(28289),c=o(43072),d=(o(11118),o(98199),o(43759),o(57209),o(55205),o(70948),o(74744)),u="wds_1_276_0_MessageBoxFunctionalLayout",p=d.rx.bind(null,u),m=(d.jF.bind(null,u),p),h="wds_1_276_0_MessageBoxFunctionalLayout__root",f="wds_1_276_0_MessageBoxFunctionalLayout__topAreaContainer",g="wds_1