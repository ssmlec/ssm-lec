urrent&&(d.current=!1,u())},[i,u]);const f=n().useCallback(()=>{d.current=!0},[]),m=n().useMemo(()=>{const e={findDashboardComponents:{execute:(e,t,n)=>{var r;if(null!=(r=n.signal)&&r.aborted)return{success:!1,content:"Cancelled."};const o=Number(e.limit),i=pte(String(e.query??""),{type:e.type?String(e.type):void 0,limit:Number.isFinite(o)?o:void 0});return{success:!0,content:JSON.stringify(i)}}},listDashboardTools:{execute:()=>({success:!0,content:JSON.stringify(ute())})},executeDashboardTool:{execute:async(e,t,n)=>{var r;if(null!=(r=n.signal)&&r.aborted)return{success:!1,content:"Cancelled."};const o=await dte(String(e.name??""),e.args??{});return{success:!0,content:JSON.stringify(o)}}}};return{resolveBuilderClientTool:t=>e[t]}},[]);return n().createElement(gQ,{key:c,asset:IQ(a,t),errorReportingUrl:SQ(a,t)||"",isPermitted:yQ(a,t),componentId:t,wrapperComponentId:sv(a),title:TQ(a,t),ErrorComponent:()=>n().createElement(mte,{onClose:s,onErrored:f}),NoPermissionComponent:()=>null,LoaderComponent:hte,externalProps:{...l,closeAiAssistant:s,topLayer:r,setTopLayer:o,toolRegistry:m}})},gte=e=>{let{open:t,onClose:r,children:o}=e;return n().createElement(vD,{dataHook:"ai-assistant-mobile-drawer",open:t,onClose:r,margin:!1,dismissible:!0,zIndex:6e3},n().createElement(Jb,{width:"100%",height:"calc(100dvh - 73px)"},n().createElement("div",{"data-hook":"ai-assistant-mobile-content",style:{height:"100%",width:"100%"}},o)))},_te=JSON.parse('{"2e96bad1-df32-47b6-942f-e3ecabd74e57":{"compType":"BACK_OFFICE_PAGE","compName":"SetupAndGrow","aiContext":{"description":"Purpose: Setup and Grow page (onboarding and growth tasks hub) in Business Manager. Presents a checklist or dashboard of recommended setup steps and growth actions to help the site owner get their business running and expanding. Users come here to complete onboarding tasks, follow setup guides, or discover growth recommendations.\\nAlso known as: get started, setup checklist, grow my business, onboarding, setup guide."}},"dfad075a-1ab3-458c-a77b-8fc9f509eaca":{"compType":"BACK_OFFICE_PAGE","compName":"BusinessOverview","aiContext":{"description":"Purpose: Business Overview page \u2014 a summary dashboard giving a snapshot of key business metrics across revenue, orders, visitors, and active apps. Use this to get a quick health-check of the business at a glance.\\nAlso known as: overview, business summary, dashboard overview, performance snapshot, site overview."}},"10442f06-be4f-450a-8a74-0b430edbfcb8":{"compType":"BACK_OFFICE_PAGE","compName":"premium-express-checkout-bm-pages-bundle-selection","aiContext":{"description":"Purpose: The domain-purchase split page for the logged-in / Business Manager context. The user chooses between two paths: buy a domain on its own (domain only) or buy a domain bundled with a Wix Premium plan (domain + plan). Distinct from the storefront split page, which serves anonymous users who are not logged in to Wix.\\nAlso known as: split page, bundle selection, domain only or domain plus plan, domain and premium plan, choose domain plan, express checkout."}},"d4d50f19-5981-4715-a046-a8ceb35f6aa9":{"compType":"BACK_OFFICE_PAGE","compName":"DOMAINS_CONCIERGE.pages.index","aiContext":{"description":"Purpose: The \\"Add Domain\\" Concierge guided setup page. A search-first wizard where the user searches for a domain and then takes the matching action: buy a new domain, connect or transfer in an existing external domain, assign a domain the account already owns, or renew one \u2014 with assisted guidance and AI chat help.\\nAlso known as: add domain, buy domain, purchase domain, get a domain, connect domain, transfer domain, assign domain, domain setup, domain wizard, domain concierge, custom domain setup."}},"2764a351-3d1b-4e31-b173-818a0ffae5ad":{"compType":"BACK_OFFICE_PAGE","compName":"website-channel-page","aiContext":{"description":"Purpose: The Website channel page in Business Manager, showing the user\'s website as a marketing/sales channel alongside others (e.g., social, email). Users view website performance metrics, manage site visibility, and navigate to related website settings or editor.\\nAlso known as: website channel, site channel, my website overview, website sales channel."}},"50103805-f706-428a-ab43-04579324d067":{"compType":"BACK_OFFICE_PAGE","compName":"settings-lobby","aiContext":{"description":"Purpose: Settings lobby / home page in Business Manager. Central hub that lists all available site settings categories, letting users navigate to specific settings areas (payments, domains, notifications, etc.). Users land here when they open Settings and then navigate to a sub-section.\\nAlso known as: settings home, settings overview, site settings, settings menu."}},"abe22932-49cb-43e0-b22d-8e342482113e":{"compType":"BACK_OFFICE_PAGE","compName":"cashier-merchant-settings","aiContext":{"description":"Purpose: Payments (Cashier) Merchant Settings page where the user configures their payment provider credentials, connects or updates payment methods (credit card processors, PayPal, etc.), and manages merchant account details.\\nAlso known as: payment settings, payment methods, merchant account, cashier settings, payment provider, accept payments."}},"3aeabb6d-0bc6-4b88-a6ba-3b40096a9c3a":{"compType":"BACK_OFFICE_PAGE","compName":"MY_DOMAINS_IFRAME_WRAPPER.pages.index","aiContext":{"description":"Purpose: Domains management page. Shows all custom domains connected to or purchased for this site. Use this to add a new domain, connect an existing domain, renew, transfer, or configure DNS settings.\\nAlso known as: my domains, domain settings, custom domain, DNS, domain manager."}},"baf8b254-72c1-417b-a546-ecc9d869aa71":{"compType":"BACK_OFFICE_PAGE","compName":"SEO setup","aiContext":{"description":"Purpose: SEO Setup wizard or settings page in Business Manager. Guides the site owner through configuring search engine optimization settings: meta tags, site description, structured data, and indexing preferences. Users come here to improve their site\'s Google ranking, set up SEO basics, or complete the SEO setup checklist.\\nAlso known as: SEO settings, search engine optimization, Google SEO, SEO wizard, get found on Google."}},"c756378f-3438-41c6-a686-85e9fb0193ac":{"compType":"BACK_OFFICE_PAGE","compName":"bookings-services-list-page","aiContext":{"description":"Purpose: Wix Bookings services list \u2014 the catalog of all bookable services offered by the business. View, search, enable/disable, duplicate, or delete services (appointments, classes, courses). Navigate here to add a new service or manage existing ones.\\nAlso known as: offerings, services catalog, bookable services."}},"c821a776-85a9-4340-ae94-e08876c99944":{"compType":"BACK_OFFICE_PAGE","compName":"wixstores-dashboard-product-list.pages.index","aiContext":{"description":"Purpose: Wix Stores product list page. View, search, filter, and manage all products in your store. Access bulk actions, duplicate products, and navigate to individual product editors.\\nAlso known as: products page, all products, product catalog, manage products, store products."}},"29570214-f230-4228-9209-f09efb53f768":{"compType":"BACK_OFFICE_PAGE","compName":"website-settings-lazy","aiContext":{"description":"Purpose: Website settings page (lazy-loaded) in Business Manager. Users configure site-wide settings such as site name, favicon, language, SEO defaults, and domain-related options.\\nAlso known as: website settings, site settings, website preferences, web settings, site configuration."}},"5b29a70d-5e8a-44ed-b66c-e1b1b0bd0273":{"compType":"BACK_OFFICE_PAGE","compName":"form-app-bm.pages.form","aiContext":{"description":"Purpose: Individual form detail page within the Wix Forms back-office app. Users view responses, edit form fields, configure settings, and manage a specific form. Navigate here from the forms list.\\nAlso known as: edit form, form detail, form responses, view submissions.\\nDeep link: set `relativeUrl` to `{formId}/{tab}` or `{formId}/{tab}/{scrollTo}` \u2014 formId is a GUID, tab is one of `edit|preview|settings|submissions`, and the optional third segment scrollTo is a free string (e.g. a section to scroll to within a tab)."}},"1ae6068f-0fe6-4986-975a-3565f4147fbe":{"compType":"BACK_OFFICE_PAGE","compName":"engage-crazy-chat-lazy","aiContext":{"description":"Purpose: Inbox / live chat dashboard. Central messaging hub for all site visitor and customer conversations via Wix Chat. Users read, reply to, and manage chat threads, and see message history.\\nAlso known as: inbox, chat, messages, live chat, visitor chat, customer chat, conversations."}},"71e35f24-8eb7-41b0-b261-c2259a76372f":{"compType":"BACK_OFFICE_PAGE","compName":"business-info-over-bm","aiContext":{"description":"Purpose: Business Info settings page (Business Manager workspace) where the user manages their business\'s public details \u2014 name, address, phone, email, business hours, and category. Use this to update contact information displayed to customers.\\nAlso known as: business details, company info, store info, business profile, location settings."}},"81b89298-94eb-4b75-995b-821ff44c0b38":{"compType":"BACK_OFFICE_PAGE","compName":"getting-paid-get-started","aiContext":{"description":"Purpose: Getting Paid get-started page. Onboarding entry point for accepting payments, guiding users through setting up payment methods, invoices, and financial tools.\\nAlso known as: accept payments setup, payment onboarding, get started with payments, billing setup, monetisation setup."}},"c7b86028-b1d2-42b0-be1d-4c95b374fc7d":{"compType":"BACK_OFFICE_PAGE","compName":"social-blog-bm-posts","aiContext":{"description":"Purpose: Blog Posts list page in Business Manager. Users view all published and draft posts, create new posts, edit or delete existing ones.\\nAlso known as: all posts, blog posts, post list, manage posts, write a post, draft posts, published posts."}},"e839f784-0e31-45e6-8de8-426824a6dc2d":{"compType":"BACK_OFFICE_PAGE","compName":"AppMarket","aiContext":{"description":"Purpose: Wix App Market \u2014 the main marketplace where users discover, browse, and install third-party and Wix-built apps to extend their site. Users search by category, read app reviews, and add apps to their site.\\nAlso known as: app store, app marketplace, extensions, plugins, add apps.\\nDeep link: set `relativeUrl` to `web-solution/{appSlug}` \u2014 a human-readable app slug (e.g. `facebook`). Omit to open the marketplace home."}},"dfa14f69-1df6-4416-be3c-8e06f35d2cc7":{"compType":"BACK_OFFICE_PAGE","compName":"promote-seo-home","aiContext":{"description":"Purpose: SEO & GEO home dashboard under the Promote section. Users get a high-level view of their site\'s search and AI visibility, quick-access cards to SEO sub-tools, and recommended next steps to improve discoverability on both traditional search engines (Google, Bing) and generative AI answer engines (ChatGPT, Perplexity, Google AI Overviews). GEO stands for Generative Engine Optimization.\\nAlso known as: SEO dashboard, GEO dashboard, search engine optimization home, generative engine optimization, SEO & GEO overview, improve SEO, get found on Google, AI search visibility."}},"db6319e8-f8d6-4de3-830e-917d4e5c6d47":{"compType":"BACK_OFFICE_PAGE","compName":"bookings-service-form-page","aiContext":{"description":"Purpose: Wix Bookings service page \u2014 view, create, or edit a single bookable service. Opening a specific service shows its details (name, description, duration, pricing, assigned staff, locations, images, booking form) and lets you edit them. Sibling: the services list shows all services; this is the per-service detail/edit form.\\nAlso known as: view service, show service, open service, my service, service details, edit service, service settings.\\nDeep link: set `relativeUrl` to `{serviceId}` \u2014 a GUID (the bookings service id). Omit to open the default view."}},"a7f877e0-69ac-459f-8b5b-eb7c5e25bad2":{"compType":"BACK_OFFICE_PAGE","compName":"social-blog-bm","aiContext":{"description":"Purpose: Wix Blog main dashboard page in Business Manager. Users get a top-level overview of their blog and navigate to posts, comments, categories, and settings.\\nAlso known as: blog home, blog dashboard, my blog, blog overview, blog management.\\nDeep link: set `relativeUrl` to `{postId}/edit` \u2014 a draft post GUID or slug. The postId is required to open the post editor; if omitted, the page redirects to the root blog dashboard."}},"c5f0cd28-3391-4e17-aeb8-affa94867daf":{"compType":"BACK_OFFICE_PAGE","compName":"portfolio.pages.ai-cluster","aiContext":{"description":"Purpose: AI clustering or AI-generated grouping page within the Portfolio feature. Users review or apply AI-suggested clusters/categories for their portfolio content to help organise projects automatically.\\nAlso known as: portfolio AI cluster, AI organise portfolio, smart portfolio grouping, AI categories."}},"e053e11f-dd5b-433a-9c0c-3e19d44624d4":{"compType":"BACK_OFFICE_PAGE","compName":"MY_MAILBOXES_SITE_LEVEL.pages.index-mailboxes","aiContext":{"description":"Purpose: Mailboxes list page (site-level). Displays all active email mailboxes tied to the site\'s domain, with status and storage info for each account. Use this to see existing mailboxes, check capacity, or access individual mailbox settings.\\nAlso known as: email accounts list, mailbox overview."}},"816efba8-5d41-4831-84cc-9991894d62e4":{"compType":"BACK_OFFICE_PAGE","compName":"services-templates-root-component-id","aiContext":{"description":"Purpose: Bookings service presets / templates gallery (ServicePresetsCatalog). Shows a catalog of pre-built service templates that a Wix Bookings merchant can use as a starting point when creating a new service. Users come here to pick a service template, browse preset service types, or quickly add a service from a template.\\nAlso known as: service templates, booking templates, service presets, add service from template."}},"6ad740cd-b6f2-4bd7-9721-028dfeff4697":{"compType":"BACK_OFFICE_PAGE","compName":"portfolio.pages.projects","aiContext":{"description":"Purpose: All-projects list page within the Portfolio feature. Users see every portfolio project they have created, create new projects, and open individual project edit pages. Distinct from the portfolio index/dashboard and single-project page.\\nAlso known as: portfolio projects, all projects, project list, manage portfolio projects."}},"7c8f91b9-0b65-47ee-92eb-37c1f9a4d410":{"compType":"BACK_OFFICE_PAGE","compName":"social-blog-bm-OVERVIEW","aiContext":{"description":"Purpose: Blog Overview / stats page in Business Manager. Users see high-level blog performance metrics such as post counts, views, and subscriber numbers.\\nAlso known as: blog overview, blog stats, blog analytics, blog summary, blog performance."}},"4244b89d-3cbb-48a8-a77f-7a97c810f83a":{"compType":"BACK_OFFICE_PAGE","compName":"brand-maker-biz-mgr","aiContext":{"description":"Purpose: Brand Maker page in Business Manager where the user creates and edits their business brand assets \u2014 logo, color palette, fonts, and visual identity. Use this page to build or update a brand kit, generate a logo, set brand colors and typography.\\nAlso known as: branding, brand kit, logo maker, visual identity, brand design."}},"8107f05f-d646-4c81-be90-adf28d321398":{"compType":"BACK_OFFICE_PAGE","compName":"ecom-platform-dashboard-orders-list.pages.index","aiContext":{"description":"Purpose: Orders list page \u2014 the main eCommerce orders dashboard. Browse, search, and filter all store orders by status, date, or customer. Entry point for managing the full order pipeline.\\nAlso known as: orders, all orders, view orders, order management, sales orders."}},"5a66867d-34ef-4ee7-a10d-69d87c94e034":{"compType":"BACK_OFFICE_PAGE","compName":"Manage Apps BM Page","aiContext":{"description":"Purpose: Manage Apps page in the Wix Business Manager back-office. Shows all installed third-party and Wix apps for this site. Users install new apps, update, configure, or uninstall existing ones from here.\\nAlso known as: installed apps, my apps, app management, app dashboard."}},"bdd09dca-7cc9-4524-81d7-c9336071b33e":{"compType":"BACK_OFFICE_PAGE","compName":"contacts-page-component","aiContext":{"description":"Purpose: The main Contacts list page in the Wix CRM. Users view, search, filter, and manage all site contacts; open individual contact cards; add new contacts; and perform bulk actions like tagging or emailing.\\nAlso known as: contacts, contact list, CRM contacts, address book, customer list."}},"e8ad3b9b-a7cd-4a3e-aeb3-54924942414c":{"compType":"BACK_OFFICE_PAGE","compName":"ecom-product-virtual","aiContext":{"description":"Purpose: Wix Stores product page \u2014 the legacy Catalog V1 Stores back-office (route `store/products/product`). On a V1 site this is where you view and edit a product. (Not a digital/virtual-goods page \u2014 the legacy component is just named `ecom-product-virtual`.)\\nAlso known as: stores products (V1), legacy stores, manage products, edit product, stores dashboard.\\nApplies when: the site\'s Wix Stores catalog version is V1 \u2014 check the site context first. Do NOT use on Catalog V3 sites; for V3 use the product editor `a6af8b0b-4e9d-4a40-991a-6a1058109287`.\\nDeep link: set `relativeUrl` to `{productId}` \u2014 the Wix Stores product GUID. Omit to open the default view."}},"67028126-3a56-43dd-9ed2-0c9c875e739c":{"compType":"BACK_OFFICE_PAGE","compName":"crm-automations","aiContext":{"description":"Purpose: Automations home page in Business Manager \u2014 the main entry point for Wix Automations. Users see all their automations and create or manage automated workflows that trigger actions (emails, tasks, labels, and more) from contact behavior or site events. Distinct from the archived-automations view and the single-automation editor.\\nAlso known as: automations, my automations, workflows, triggers, email automations, automation rules, marketing automation, smart actions.\\nDeep link: open plain to see the automations list; pass `?recipe={recipeId}` to start creating an automation from a specific recipe (the page redirects to the automation wizard)."}},"1655fec5-6533-431d-a9a8-eb29f3ae7e1b":{"compType":"BACK_OFFICE_PAGE","compName":"analytics-ng-highlights","aiContext":{"description":"Purpose: Analytics Highlights overview page \u2014 the main analytics home/summary view. Displays top-level KPIs such as visits, revenue, conversions, and traffic sources in a snapshot. Users get a quick read on site performance at a glance.\\nAlso known as: analytics overview, analytics home, stats summary, highlights dashboard."}},"bfd22a01-fc5b-4b53-940d-beaeac065230":{"compType":"BACK_OFFICE_PAGE","compName":"MY_MAILBOXES_SITE_LEVEL.pages.index","aiContext":{"description":"Purpose: Wix Email Mailboxes overview page (site-level). Entry point for managing professional email mailboxes associated with the site\'s domain. Use this to view all mailboxes, purchase a mailbox plan, or navigate to mailbox setup.\\nAlso known as: email accounts, professional email, business email, Wix Email."}},"320f8508-3832-4861-82c8-260e2b68bc8d":{"compType":"BACK_OFFICE_PAGE","compName":"portfolio.pages.index","aiContext":{"description":"Purpose: Portfolio dashboard/index \u2014 the main landing page for the Wix Portfolio section. Users get an overview of their portfolio, access recent projects and collections, and navigate to sub-sections.\\nAlso known as: portfolio home, portfolio dashboard, open portfolio, my portfolio."}},"c8cde3d5-1088-431e-bfc9-479adc2b0428":{"compType":"BACK_OFFICE_PAGE","compName":"portfolio-pages-project","aiContext":{"description":"Purpose: Single-project detail/edit page within the Portfolio feature. Users view and edit one portfolio project \u2014 updating title, description, images, tags, and collection membership. Distinct from the projects list page.\\nAlso known as: portfolio project, edit project, update project, project details.\\nDeep link: set `relativeUrl` to `{projectId}` \u2014 a Portfolio project GUID (the route value is used directly as projectId/effectiveId; a slug-based inner route is resolved separately via getProjectIdBySlug). Omit to open the default view."}},"ad471122-7305-4007-9210-2a764d2e5e57":{"compType":"BACK_OFFICE_PAGE","compName":"AppMarket/Manage","aiContext":{"description":"Purpose: App Market Manage page \u2014 lists all apps currently installed on the site. Users view, open settings for, or remove installed apps. Distinct from the main App Market discovery page (which shows all available apps); this is the installed/active-apps management view.\\nAlso known as: manage apps, installed apps, my apps."}},"8d2f23a0-a6de-47fa-994c-62c3c015b47b":{"compType":"BACK_OFFICE_PAGE","compName":"proactive-marketing-assistant-bm-components-pages-index","aiContext":{"description":"Purpose: Proactive Marketing Assistant onboarding page (PMA). Entry point where users are introduced to and activate the AI-powered marketing assistant. Users step through the onboarding flow to connect the assistant to their business before it begins generating marketing suggestions.\\nAlso known as: marketing assistant setup, PMA onboarding, activate marketing AI, marketing automation intro. See also: proactive-marketing-assistant-page for the main assistant workspace."}},"4431cdc6-904e-4937-9aac-f0b7fc181e05":{"compType":"BACK_OFFICE_PAGE","compName":"promote-seo-settings","aiContext":{"description":"Purpose: SEO Settings page. Users configure SEO defaults for site page types, including title and meta description templates, canonical URL tags, robots meta tag/indexing settings, and structured data settings.\\nAlso known as: SEO settings, search settings, meta tags, robots meta tag, structured data, site SEO configuration, default SEO."}},"6617e07c-c3f3-45eb-9280-b41f23f259dd":{"compType":"BACK_OFFICE_PAGE","compName":"PromoteHomeLazyComponent","aiContext":{"description":"Purpose: Marketing home (Promote hub / Ascend marketing home). Central hub for all marketing tools and campaigns. Users see an overview of their marketing channels, access email campaigns, social posts, SEO, and paid ads, and get marketing recommendations.\\nAlso known as: marketing dashboard, promote home, ascend, marketing overview, marketing hub, campaigns home."}},"bbbc8c7d-19b9-4a86-bfc5-1bf59208b01b":{"compType":"BACK_OFFICE_PAGE","compName":"bookings-calendar-page-lazy-component-id","aiContext":{"description":"Purpose: Wix Bookings calendar view \u2014 a visual day/week/month agenda of all appointments and availability. See bookings plotted on a calendar, manage staff schedules, block off time, and handle walk-in or manual bookings. Sibling: bookings list (tabular view).\\nAlso known as: schedule view, appointments calendar, availability calendar."}},"832347c3-d9d4-4f02-9a89-6b3778a07c14":{"compType":"BACK_OFFICE_PAGE","compName":"analytics-ng-bm.pages.overviews.traffic","aiContext":{"description":"Purpose: Traffic analytics overview page. Reports on where site visitors come from \u2014 organic search, direct, social, referral, email \u2014 with session counts and trends over time.\\nAlso known as: traffic report, visitor sources, acquisition analytics, where traffic comes from, site visitors."}},"e40fa9cb-05a6-4d40-977c-8ffec0e9a679":{"compType":"BACK_OFFICE_PAGE","compName":"e40fa9cb-05a6-4d40-977c-8ffec0e9a679","aiContext":{"description":"Purpose: The New Product creation page in Wix Stores. Users fill in a product name, description, images, price, inventory, variants, and other details to add a brand-new product to their store catalog. Distinct from the product list and the product edit page.\\nAlso known as: add product, create product, new product, add item to store."}},"122ec73e-4e5d-4c3a-ad62-3f62bdb31e0f":{"compType":"BACK_OFFICE_PAGE","compName":"site-history-client","aiContext":{"description":"Purpose: Site History page showing a chronological log of changes made to the site. Users review past versions, compare revisions, and restore earlier site states.\\nAlso known as: revision history, change log, version history, undo history, restore site, site revisions, rollback."}},"ca4fc2e2-e8fc-4b4c-bfa0-32479931a00a":{"compType":"BACK_OFFICE_PAGE","compName":"roles-and-permissions","aiContext":{"description":"Purpose: Roles and Permissions main page in Business Manager. Entry point for all team and access management: view collaborators, manage roles, invite new members. Users come here to control who has access to the site and what they can do.\\nAlso known as: team access, permissions, collaborators, site roles, member management."}},"2f8f08fe-b611-4c9f-9320-c8584073427c":{"compType":"BACK_OFFICE_PAGE","compName":"automations-builder-pages-idx","aiContext":{"description":"Purpose: Edit page for a single automation rule \u2014 the editor for one existing automation, identified by its id. Users modify an existing automation\'s trigger, conditions, and actions. Distinct from the automations list/home and the create-new-automation pages; this edits one specific automation.\\nAlso known as: edit automation, automation builder, edit automation rule, modify automation.\\nDeep link: set `relativeUrl` to `{idx}` \u2014 a required automation GUID. Do not omit; without an id there is no automation to edit."}},"8834b0a0-8d32-4a25-a060-2cfb93af1ba0":{"compType":"BACK_OFFICE_PAGE","compName":"mobile-app.pages.dashboard","aiContext":{"description":"Purpose: Dashboard overview for the Wix Owner mobile app management section. Provides a summary of the mobile app\'s status, activity metrics, and quick-access actions for managing the site\'s branded mobile application. Use this to get a high-level view of the mobile app.\\nAlso known as: mobile app home, mobile dashboard."}},"4f7a3c63-1ff3-4b66-957d-d7075ab07bba":{"compType":"BACK_OFFICE_PAGE","compName":"rnp-pages-collaborators-business-manager","aiContext":{"description":"Purpose: Collaborators list page within Roles & Permissions (RNP) in Business Manager. Displays all people who have access to the site, their roles, and their status. Users come here to review who has site access and manage collaborators \u2014 invite or remove them.\\nAlso known as: collaborators, site collaborators, site contributors, who has access."}},"ed18a826-923e-4423-bc72-6882e6fcf336":{"compType":"BACK_OFFICE_PAGE","compName":"pa-google-web.pages.index","aiContext":{"description":"Purpose: Google advertising integration page (Partner Ads). Connect and manage Google Ads campaigns from the Business Manager back-office. Use this to set up Google Ads, track ad performance, configure conversion tracking, or manage Smart Campaigns.\\nAlso known as: Google Ads, Google marketing, search advertising, SEM."}},"b391e304-bf35-40f6-a9dc-08a213ef9927":{"compType":"BACK_OFFICE_PAGE","compName":"portfolio-pages-collections","aiContext":{"description":"Purpose: All-collections list page for the Portfolio feature. Users see every portfolio collection they have created, create new collections, and navigate into individual collection detail pages. Distinct from the single-collection page.\\nAlso known as: portfolio collections, all collections, my collections, portfolio gallery groups."}},"efe44d1d-506c-46c7-a770-e212b697acf0":{"compType":"BACK_OFFICE_PAGE","compName":"Business Manager","aiContext":{"description":"Purpose: Business Manager home \u2014 the top-level back-office dashboard for a Wix site in the Business Manager workspace. Entry point for navigating to all management sections: analytics, marketing, store, bookings, CRM, and settings.\\nAlso known as: dashboard, home, back office, admin panel, site management, control panel."}},"1a647c6b-8adc-4696-b8b4-8103328d0a85":{"compType":"BACK_OFFICE_PAGE","compName":"portfolio-pages-collection","aiContext":{"description":"Purpose: Single-collection detail/edit page within the Portfolio feature. Users view and manage one specific portfolio collection \u2014 reordering projects, editing the collection name and description, or adding/removing projects. Distinct from the collections list page.\\nAlso known as: portfolio collection, edit collection, manage collection projects.\\nDeep link: set `relativeUrl` to `{collection}` \u2014 a Portfolio collection slug (resolved to an id via getCollectionIdBySlug; the literal \'new\' is a special create route). Omit to open the default view."}},"66f6b3e3-a381-4b99-8d0e-18d05300951e":{"compType":"BACK_OFFICE_PAGE","compName":"premium-express-checkout-bm-pages-storefront-bundle-selection","aiContext":{"description":"Purpose: The domain-purchase split page for the storefront flow \u2014 the dedicated version served to anonymous users who are not logged in to Wix. Same choice as the standard split page: buy a domain on its own (domain only) or a domain bundled with a Wix Premium plan (domain + plan). Here \\"storefront\\" means the anonymous/logged-out entry point, not eCommerce.\\nAlso known as: storefront split page, anonymous domain purchase, logged-out domain checkout, guest domain purchase, domain only or domain plus plan."}},"6a487adb-8421-4188-b7f1-aa58d2a7bf1c":{"compType":"BACK_OFFICE_PAGE","compName":"lazy-events","aiContext":{"description":"Purpose: Wix Events main page listing all events for the site. Users view upcoming and past events, create new events, manage RSVPs and tickets, and access event analytics.\\nAlso known as: events, all events, event list, manage events, tickets, RSVP, event management."}},"66aeefcd-3e60-4b41-8991-934c5ee331ec":{"compType":"BACK_OFFICE_PAGE","compName":"analytics-ng-bm","aiContext":{"description":"Purpose: Main Analytics dashboard home. Entry point for site analytics; displays a summary of key metrics across traffic, sales, and behavior with navigation to detailed analytics reports.\\nAlso known as: analytics home, stats, site analytics, data dashboard, reports home."}},"6a83b360-7c84-495e-920b-7bea6417f174":{"compType":"BACK_OFFICE_PAGE","compName":"payment-links-bm.pages.index","aiContext":{"description":"Purpose: Payment Links management page. Create and manage standalone payment links that can be shared with customers to collect one-time or recurring payments without a full checkout flow. Use this to generate a payment link, view existing links, or track payment status.\\nAlso known as: pay links, payment requests, invoices, collect payment."}},"59a8855e-515a-49c1-894a-035731d2fd44":{"compType":"BACK_OFFICE_PAGE","compName":"wixstores-dashboard-inventory.pages.index-v2-cairo","aiContext":{"description":"Purpose: Wix Stores inventory management page (v2 Cairo). Track and update stock levels, variants, and SKUs across all products. Bulk-edit quantities, set low-stock thresholds, and manage inventory per variant.\\nAlso known as: stock levels, inventory, manage stock, product inventory, quantities."}},"27d19405-24bf-4637-8794-a943aa738d4d":{"compType":"BACK_OFFICE_PAGE","compName":"ECOM/Collections","aiContext":{"description":"Purpose: Product collections page for the eCommerce store. Create and manage curated groups of products (collections/categories) displayed on the storefront. Users add products to collections, reorder them, and control visibility.\\nAlso known as: collections, categories, product groups, shop collections, store categories."}},"9139f2b9-a280-4218-80df-01c91969cc89":{"compType":"BACK_OFFICE_PAGE","compName":"inbox-settings-lazy","aiContext":{"description":"Purpose: Wix Inbox settings page (lazy-loaded). Users configure inbox preferences, notifications, and general messaging settings. Distinguish from the communication channels settings sub-page.\\nAlso known as: inbox settings, messaging settings, inbox preferences, chat settings."}},"b519596d-00fa-4a10-8fe9-9ab87819b12a":{"compType":"BACK_OFFICE_PAGE","compName":"rnp-pages-invite-business-manager","aiContext":{"description":"Purpose: Invite collaborator page within Roles & Permissions (RNP) in Business Manager. Send an invitation for a new person to join the site with a chosen role. Users come here to add a new collaborator, send an invite, grant access.\\nAlso known as: add collaborator, invite collaborator, invite contributor, add member."}},"841919b4-9e96-43f4-87ea-fa382bc9d0e8":{"compType":"BACK_OFFICE_PAGE","compName":"delivery-profiles.pages.index","aiContext":{"description":"Purpose: The Delivery Profiles list page for Wix eCommerce shipping settings. Users view, create, and manage delivery profiles that define shipping rates, regions, and carriers for their store.\\nAlso known as: delivery profiles, shipping profiles, shipping settings, shipping rates, delivery settings.\\nDeep link: set `relativeUrl` to `{profileId}` \u2014 an eCom delivery-profile GUID (read from query.profileId as string). Omit to open the default view."}},"6513755b-2a3b-45b9-8172-99c16e00dfde":{"compType":"BACK_OFFICE_PAGE","compName":"DATABASE/database","aiContext":{"description":"Purpose: The Wix Database (Content Manager) page. Users create and manage database collections (tables), define schemas/fields, add/edit/delete content rows, and set permissions.\\nAlso known as: database, content manager, CMS, collections, data tables, site database."}},"98b6ed3b-9ac6-486f-a347-0de6f9929965":{"compType":"BACK_OFFICE_PAGE","compName":"google-my-business.pages.index","aiContext":{"description":"Purpose: Google My Business integration page. Users connect their Google Business Profile, manage their listing, and sync business info between Wix and Google.\\nAlso known as: Google Business Profile, GMB, Google listing, Google Maps listing, local SEO, connect Google Business."}},"a6af8b0b-4e9d-4a40-991a-6a1058109287":{"compType":"BACK_OFFICE_PAGE","compName":"wixstores-dashboard-product-page-pages-id","aiContext":{"description":"Purpose: Wix Stores product editor \u2014 the Catalog V3 standalone product page (route `wix-stores/products/product`). Edit an individual product\'s details: title, description, media, pricing, variants, shipping, and SEO. Reached from the product list via the product id.\\nAlso known as: edit product (V3), product editor, product settings, update product, product details.\\nApplies when: the site\'s Wix Stores catalog version is V3 \u2014 check the site context first. Do NOT use on Catalog V1 sites; for V1 use the legacy Stores product page `e8ad3b9b-a7cd-4a3e-aeb3-54924942414c`.\\nDeep link: set `relativeUrl` to `{productId}` \u2014 the Wix Stores product GUID."}},"37c3de13-6224-42ee-bd80-308d452a2c7d":{"compType":"BACK_OFFICE_PAGE","compName":"restaurants-menus-showcase","aiContext":{"description":"Purpose: Restaurant menus showcase page for Wix Restaurants. Lets the owner view and manage their menus in a card/gallery layout before publishing. Users come here to browse menus, preview menu structure, and navigate into editing a specific menu.\\nAlso known as: menus overview, menus gallery, showcase menus, restaurant menu list."}},"c44319c0-701a-4e90-8244-460ac3505263":{"compType":"BACK_OFFICE_PAGE","compName":"automations-builder.pages.create.index","aiContext":{"description":"Purpose: Create New Automation page \u2014 the automation builder for creating a new rule from scratch or from a template. Users pick a trigger (e.g., form submitted, order placed), add conditions, and configure actions (e.g., send email, assign label). Distinct from the automations list (which shows existing ones).\\nAlso known as: new automation, build automation, create trigger, set up automation."}},"f1f1abd6-3949-4633-a6dc-74337c70957a":{"compType":"BACK_OFFICE_PAGE","compName":"language-and-region-lazy","aiContext":{"description":"Purpose: Language and region settings page (lazy-loaded). Users set the site\'s language, locale, date/time format, currency, and regional preferences.\\nAlso known as: language settings, region settings, locale, currency settings, date format, time zone, multilingual settings."}},"258db196-97ab-4d0c-8e5e-2b95897f7e12":{"compType":"BACK_OFFICE_PAGE","compName":"site-subscriptions-lazy-component-legacy","aiContext":{"description":"Purpose: Site Subscriptions management page (legacy) where users view and manage recurring subscription plans sold through the site. Users see subscriber lists, subscription statuses, and billing details.\\nAlso known as: subscriptions, recurring plans, membership plans, paid plans, subscriber management."}},"016cbe73-3e6d-460c-9acc-b536399db1d8":{"compType":"BACK_OFFICE_PAGE","compName":"bookings-availability-management-pages-default-hours","aiContext":{"description":"Purpose: Bookings Default Hours page within Availability Management. Sets the default working-hour schedule applied to all staff and resources unless overridden individually. Users define open/closed days and time ranges that serve as the baseline availability template.\\nAlso known as: default schedule, business hours, default availability, working hours template."}},"e04f56ae-410c-426c-9763-367893430872":{"compType":"BACK_OFFICE_PAGE","compName":"wix-video-library.videos","aiContext":{"description":"Purpose: Wix Video library \u2014 Videos management page. View, upload, organize, and manage all videos in your Wix Video library. Set pricing, privacy, and metadata for individual videos.\\nAlso known as: my videos, video list, video library, manage videos, upload video."}},"6a892f7e-2b56-4ce9-a889-ab038487ceab":{"compType":"BACK_OFFICE_PAGE","compName":"site-subscriptions-lazy-component-legacy2","aiContext":{"description":"Purpose: Site Subscriptions management page (legacy variant 2) \u2014 a second legacy entry point for recurring subscription plan management. Functionally equivalent to the primary legacy subscriptions page; users manage subscriber plans and billing from here.\\nAlso known as: subscriptions, paid plans, recurring billing, subscriber list."}},"6ae5e416-a883-42aa-8d8b-cdae6d7c2662":{"compType":"BACK_OFFICE_PAGE","compName":"MarketingIntegrationComponent","aiContext":{"description":"Purpose: Marketing Integrations page (also known as Tracking Chef) \u2014 connects third-party marketing and tracking tools to a Wix site. Users add, configure, and manage integrations such as Google Tag Manager, Facebook Pixel, TikTok Pixel, and other ad/analytics trackers.\\nAlso known as: marketing integrations, tracking integrations, pixel setup, ad tracking, tag manager."}},"fd3e1c66-89b0-44ee-b824-1a28cc1a6dde":{"compType":"BACK_OFFICE_PAGE","compName":"social-blog-categories","aiContext":{"description":"Purpose: Blog Categories management page. Users create, rename, reorder, and delete topic categories used to organise blog posts.\\nAlso known as: blog categories, post categories, organise blog, blog topics, category list."}},"237552b5-9d8e-4bdc-a39b-6e70a83caea0":{"compType":"BACK_OFFICE_PAGE","compName":"invoices","aiContext":{"description":"Purpose: Invoices list page. Users view all invoices sent to clients, check statuses (draft, sent, paid, overdue), create new invoices, and follow up.\\nAlso known as: invoices, invoice list, billing, client invoices, all invoices, view invoices, send invoice.\\nDeep link: this is the invoices list page and has no route parameters \u2014 omit `relativeUrl` to open it. A specific invoice opens via the invoice editor page, not from here."}},"4ce7d583-0997-444a-962e-f337dbb88fba":{"compType":"BACK_OFFICE_PAGE","compName":"social-marketing-web","aiContext":{"description":"Purpose: Social marketing hub for scheduling and publishing posts to social media channels (Facebook, Instagram, etc.). Users create, preview, schedule, and track social posts from one place.\\nAlso known as: social posts, social scheduler, post to social, social media marketing, share to social.\\nDeep link: set `relativeUrl` to `?tab={tabId}` \u2014 a tab key, one of \'planner\' or \'my-posts\' (validated against the WidgetTab enum). Omit to open the default view."}},"5aac0778-4404-4931-9ac6-bc64f512d721":{"compType":"BACK_OFFICE_PAGE","compName":"wixstores-dashboard-product-page-new-product","aiContext":{"description":"Purpose: Wix Stores new product creation page. Add a brand-new product to your store \u2014 set name, description, images, pricing, variants, and inventory from scratch. Distinct from the existing-product editor.\\nAlso known as: add product, create product, new product, add item to store."}},"50f142b8-f7aa-45eb-98f1-7a7044d797b7":{"compType":"BACK_OFFICE_PAGE","compName":"events-event-details","aiContext":{"description":"Purpose: Event details page for a single Wix Event. View and edit all settings for one event: title, date, location, tickets, registration, and publishing status. Entry point for managing a specific event end-to-end.\\nAlso known as: event settings, edit event, event info, event page.\\nDeep link: set `relativeUrl` to `{eventId}` \u2014 a GUID (the Wix Events event id)."}},"99bc7dcb-312d-4462-9ff6-ca764606cfbb":{"compType":"BACK_OFFICE_PAGE","compName":"rise-client-dashboard.pages.index","aiContext":{"description":"Purpose: Main Gift Cards management page (Rise client dashboard). Lists all gift cards issued \u2014 active, redeemed, and expired \u2014 and lets the merchant create new gift cards or manage existing ones. Users come here to view, search, issue, or void gift cards.\\nAlso known as: gift cards list, Rise dashboard, gift card management, ecom gift cards."}},"ecada1b5-587e-4be4-9030-5674d547c5c4":{"compType":"BACK_OFFICE_PAGE","compName":"inbox-settings-pages-communication-channels","aiContext":{"description":"Purpose: Inbox communication channels settings page. Users add, remove, or configure channels connected to Wix Inbox (e.g. Instagram, Facebook, phone, email). Distinct from general inbox settings.\\nAlso known as: communication channels, inbox channels, connect channels, messaging channels, social channels setup."}},"721e291d-190c-4a61-ac29-da6a244d414b":{"compType":"BACK_OFFICE_PAGE","compName":"IndexPage","aiContext":{"description":"Purpose: Generic Business Manager index / home page. Serves as the main landing page or dashboard when navigating to the root of an app section.\\nAlso known as: home page, main page, dashboard, app index, start page."}},"0834cd36-cfdc-4018-875a-8259907daa7e":{"compType":"BACK_OFFICE_PAGE","compName":"events-new","aiContext":{"description":"Purpose: Create new event page. Step-by-step form to set up a brand-new Wix Event from scratch \u2014 enter event name, date, location, ticket types, and publish.\\nAlso known as: new event, add event, create event, publish event.\\nDeep link: this page always opens a blank new-event creation form and ignores any route parameter \u2014 set `relativeUrl` to empty (`new`); passing an id has no effect."}},"07e6aa6b-977b-4da1-bd60-0f4c45070059":{"compType":"BACK_OFFICE_PAGE","compName":"analytics-ng-bm.pages.performance.site-speed","aiContext":{"description":"Purpose: Site Speed analytics page within the Analytics section. Shows Core Web Vitals, page-load performance metrics, and speed scores for the site over time. Users review LCP, FID/INP, CLS scores, identify slow pages, and track speed improvements.\\nAlso known as: web performance, page speed, site performance report, core web vitals dashboard."}},"2abbf001-de3d-4b60-a186-28afd3f4c7ac":{"compType":"BACK_OFFICE_PAGE","compName":"ShoutOut","aiContext":{"description":"Purpose: ShoutOut email marketing page in Business Manager (legacy Wix ShoutOut / Email Marketing). Lets the owner create and send promotional email campaigns or newsletters to their subscriber list. Users come here to compose a new email campaign, view sent campaigns, or manage email marketing.\\nAlso known as: email campaigns, newsletters, email marketing, send email blast, ShoutOut.\\nDeep link: set `relativeUrl` to `?dl=<route>`. Supported routes: `dashboard`, `template-list`, `my-shoutouts`, `ai-create` (plain); `analytics/{campaignId}` (requires the campaign id suffix, e.g. `?dl=analytics/<id>`); and `message` (opens the email composer \u2014 use the full form `?dl=message&messageId=<id>`; `dl=message` is required, otherwise navigation falls back to the dashboard). An unrecognized or missing value opens the dashboard."}},"bfd0263f-8092-4af9-aba7-c0ed0b7b3ebc":{"compType":"BACK_OFFICE_PAGE","compName":"WelcomePage","aiContext":{"description":"Purpose: Welcome/onboarding page shown to users when they first open Business Manager or a newly created site. Users are introduced to available features and guided toward completing setup steps.\\nAlso known as: welcome page, onboarding, getting started, setup wizard, intro page."}},"044e50ef-1f24-4ff0-bae0-05713406dc7f":{"compType":"BACK_OFFICE_PAGE","compName":"analytics-ng-bm.pages.group","aiContext":{"description":"Purpose: Analytics grouped / custom report page. Allows users to view or build a grouped analytics breakdown comparing multiple metrics or segments side by side.\\nAlso known as: analytics group, segment comparison, custom analytics, grouped stats, report builder.\\nDeep link: set `relativeUrl` to `{id}` \u2014 a report id GUID (keys of REPORT_ID_MODEL_SLUG / legacy id mappings are GUIDs). Omit to open the default view."}},"4ada9d29-ff4d-40b6-802e-97dbd661fd7c":{"compType":"BACK_OFFICE_PAGE","compName":"pa-facebook-web.pages.index","aiContext":{"description":"Purpose: Facebook advertising integration page (Partner Ads). Connect and manage Facebook ad campaigns directly from the Business Manager back-office. Use this to set up Facebook Ads, review campaign performance, or configure pixel and audience targeting for the site.\\nAlso known as: Facebook Ads, Facebook marketing, social ads, Meta advertising."}},"b94dd6e3-764c-4e45-b723-96767e73a1c2":{"compType":"BACK_OFFICE_PAGE","compName":"invoices-settings","aiContext":{"description":"Purpose: Invoice settings page. Users configure invoice defaults such as business details, payment terms, tax settings, currency, and invoice numbering. Distinct from the invoices list.\\nAlso known as: invoice settings, invoice preferences, billing settings, invoice defaults, payment terms."}},"d59c5ce8-675d-4d0d-8561-6f91b046dd2f":{"compType":"BACK_OFFICE_PAGE","compName":"ecom-platform-dashboard-settings.pages.index","aiContext":{"description":"Purpose: eCommerce platform settings page. Central hub for store-wide configuration including regions, currencies, units, and general preferences. Distinct from checkout or tax settings.\\nAlso known as: store settings, ecom settings, shop settings, general ecommerce settings."}},"05a202e3-9345-40d3-afa7-92a303baf025":{"compType":"BACK_OFFICE_PAGE","compName":"restaurants-menus-management-menu","aiContext":{"description":"Purpose: Restaurant menus \u2014 menu management page. Users create and manage full menus (e.g. Lunch Menu, Dinner Menu): add/remove sections, reorder courses, set menu availability schedules, and manage menu-level settings.\\nAlso known as: restaurant menu, manage menus, create menu, menu sections, online menu, food menu management.\\nDeep link: set `relativeUrl` to `{menuId}` \u2014 a menu entity id GUID (matched against menu.id from the Menus V3 API). Omit to open the default view."}},"de8dd638-d0a2-41c2-8417-adb4fbd09f69":{"compType":"BACK_OFFICE_PAGE","compName":"c696eca6-7489-40ae-8c41-815cea571b53-alias-member-permissions-settings","aiContext":{"description":"Purpose: Member Permissions \u2014 Settings tab, where the user configures general member area settings such as member approval mode, profile privacy defaults, and community visibility. Distinct from the Members tab (member list) and Roles tab (role definitions).\\nAlso known as: member settings, permissions settings, member area settings, community settings."}},"e7b7afbb-6d4e-46b2-8bd6-0af78dc9d21e":{"compType":"BACK_OFFICE_PAGE","compName":"membership-lazy-component","aiContext":{"description":"Purpose: Pricing Plans (Memberships) page \u2014 the main back-office page for the Wix Pricing Plans feature. Users view and manage all subscription and membership plans sold on their site, including plan details, pricing, and subscriber counts.\\nAlso known as: pricing plans, memberships, subscription plans, member plans, paid plans list."}},"1fcafbe6-f6da-4c09-8a88-cf277be996fe":{"compType":"BACK_OFFICE_PAGE","compName":"contact-full-page","aiContext":{"description":"Purpose: Contact full-page view \u2014 opens a single contact\'s detailed profile in the CRM, showing all stored information: name, email, phone, activity history, labels, and associated transactions. Use this to view or edit a specific contact\'s record in full.\\nAlso known as: contact details, contact profile, CRM contact, view contact, customer profile.\\nDeep link: set `relativeUrl` to `{contactId}` \u2014 the contact GUID. Omit to open the contacts list."}},"d53c7001-5056-48d3-81e8-5320f9ef08e4":{"compType":"BACK_OFFICE_PAGE","compName":"analytics-ng-bm.pages.overviews.behavior","aiContext":{"description":"Purpose: Visitor behavior analytics overview page. Shows how visitors interact with the site \u2014 scroll depth, clicks, session duration, bounce rate, and page engagement heatmap summaries.\\nAlso known as: behavior report, visitor activity, user engagement, session analytics, on-site behavior."}},"c88f120e-6f90-4bc5-8e93-18e7aa507413":{"compType":"BACK_OFFICE_PAGE","compName":"bookings-integrations-channels-page","aiContext":{"description":"Purpose: Wix Bookings integrations and channels settings. Connect external booking channels and third-party integrations \u2014 manage sync with Google Calendar, Zoom, or other platforms, and configure which channels surface the business\'s availability.\\nAlso known as: integrations, connected channels, calendar sync."}},"9f45b934-56a1-4036-96eb-4f6e2ff15c73":{"compType":"BACK_OFFICE_PAGE","compName":"price-quotes","aiContext":{"description":"Purpose: Price Quotes (estimates/proposals) list and management page. Users create, view, send, and manage price quotes/estimates sent to clients before invoicing.\\nAlso known as: price quotes, quotes, estimates, proposals, create quote, send estimate, quote list, quote management."}},"099db19c-5c3f-475d-8a3f-1eea953e0d5e":{"compType":"BACK_OFFICE_PAGE","compName":"analytics-ng-bm.pages.overviews.realtime","aiContext":{"description":"Purpose: Real-time analytics overview page. Live view of who is on the site right now \u2014 active visitors, pages they are viewing, and live traffic sources, updating continuously.\\nAlso known as: live stats, real-time visitors, live traffic, now on site, active users."}},"f1bc7ad7-ceca-4a92-b4a7-7423ccc6f799":{"compType":"BACK_OFFICE_PAGE","compName":"faq-page-bm.pages.index","aiContext":{"description":"Purpose: FAQ page manager. Create and organize frequently asked questions displayed on the site. Users add questions and answers, group them into categories, and publish the FAQ section.\\nAlso known as: FAQ, frequently asked questions, help page, Q&A page."}},"0de2c256-c3ea-4831-9a05-5d9b7fb9d02c":{"compType":"BACK_OFFICE_PAGE","compName":"mobile-app.pages.edit-design","aiContext":{"description":"Purpose: Design editor for the Wix Owner mobile app. Lets the user customize the look and feel of their branded mobile app \u2014 colors, fonts, layout, and visual theme \u2014 without code. Use this to rebrand or restyle the app.\\nAlso known as: mobile app design, app appearance, app theme editor."}},"dda12682-9229-46e4-9ce5-eb5b398f38ae":{"compType":"BACK_OFFICE_PAGE","compName":"gmail-channel-dashboard.pages.index","aiContext":{"description":"Purpose: Gmail channel dashboard for Wix Inbox. Users connect their Gmail account as a communication channel, view Gmail-sourced conversations, and manage the Gmail integration.\\nAlso known as: Gmail inbox, connect Gmail, Gmail integration, email channel, Gmail conversations."}},"bcdb42a8-2423-4101-add6-cbebc1951bc2":{"compType":"BACK_OFFICE_PAGE","compName":"bookings-settings-page","aiContext":{"description":"Purpose: Wix Bookings general settings hub. Top-level settings for the Bookings app \u2014 business hours, location defaults, payment methods, online booking toggles, and notification preferences. Use this for site-wide bookings configuration. Distinct from the booking flow settings (funnel-specific) and individual service settings.\\nOpens as: overlay."}},"b37e1291-35d6-46a4-b21b-4ebdab21de9a":{"compType":"BACK_OFFICE_PAGE","compName":"wixstores-dashboard-categories.pages.categories.list","aiContext":{"description":"Purpose: Wix Stores product categories list page. View all product categories, reorder them, and navigate to individual category settings. Distinct from the per-category editor.\\nAlso known as: category list, all categories, store categories, manage categories, product groupings."}},"eed0ff74-9ca9-4477-bf0f-90f122650e59":{"compType":"BACK_OFFICE_PAGE","compName":"bookings-form-composer-pages-params","aiContext":{"description":"Purpose: Wix Bookings booking form composer/editor. Build or edit the form shown to clients when booking a specific service \u2014 add custom questions, set field types, mark fields required, and preview the form. Opened per form (the form ID is the path param); when starting from a service, the service is passed as a query param. Distinct from the forms manager list; this is the per-form editor.\\nDeep link: set `relativeUrl` to `{formId}/{tab}` \u2014 the first path segment is the form GUID and `tab` is e.g. `edit`. To open the composer starting from a service instead, pass it as query params: `?serviceId={serviceId}&referral=service-form`."}},"720210cb-3265-40dc-8692-555997c3c10c":{"compType":"BACK_OFFICE_PAGE","compName":"MY_MAILBOXES_SITE_LEVEL.pages.setup-users","aiContext":{"description":"Purpose: Mailbox users setup page. Guides the user through assigning or configuring users for professional email mailboxes on the site\'s domain. Use this to add new email users, assign mailboxes, or complete the mailbox onboarding flow.\\nAlso known as: email user setup, mailbox configuration, add email user."}},"a4f36fac-ea18-483b-8236-095e29fcb726":{"compType":"BACK_OFFICE_PAGE","compName":"bookings-staff-list-lazy-component-id","aiContext":{"description":"Purpose: Wix Bookings staff list \u2014 the roster of all team members available for bookings. View, add, or manage staff (employees, providers, instructors). Assign services and set availability per staff member from here. Sibling: individual staff editor for per-person settings.\\nAlso known as: team, staff members, providers list, employees."}},"66a701cc-1f39-4988-9f9e-1b54cf13fb4a":{"compType":"BACK_OFFICE_PAGE","compName":"shub-explore-products.pages.explore-products","aiContext":{"description":"Purpose: Explore Products marketplace page in Wix Suppliers Hub (shub). Lets Wix merchants browse and discover products from suppliers to add to their store for dropshipping or wholesale. Users come here to find new products to sell, browse supplier catalogs, explore the product marketplace.\\nAlso known as: explore products, product marketplace, suppliers marketplace, find products to sell, dropshipping products."}},"e107b254-7dea-4c41-acd3-3de81c65335f":{"compType":"BACK_OFFICE_PAGE","compName":"chat-dashboard","aiContext":{"description":"Purpose: Chat Dashboard page where the user monitors and manages live site chat conversations with visitors and customers. Shows active chats, chat history, and agent availability. Use this to respond to visitor messages and review chat activity.\\nAlso known as: chat, inbox, live chat, visitor chat, customer chat, messages, Wix Chat."}},"30bea83f-7db8-48da-83ed-77e4e75354ac":{"compType":"BACK_OFFICE_PAGE","compName":"promote-seo-inspection-tool","aiContext":{"description":"Purpose: Site Inspection page. Users inspect their site\'s pages with Google Search Console data to review indexing status, coverage/crawl details, and rich results, then open page-level details or re-inspect pages.\\nAlso known as: Site Inspection, URL inspection, SEO inspector, page indexing check, Google Search Console inspection, rich results check."}},"298a70bf-b6b9-41b8-b3db-6368e0b90ea5":{"compType":"BACK_OFFICE_PAGE","compName":"atlantic.pages.onboarding","aiContext":{"description":"Purpose: Wix Multilingual (Atlantic) onboarding page \u2014 the initial setup flow for enabling multilingual on a site. Users select their primary and additional languages and configure basic translation settings for the first time. Only relevant when multilingual has not yet been set up.\\nAlso known as: multilingual setup, translation setup, set up languages."}},"3b9b5f2b-adc9-4099-80e6-5e74bc30e613":{"compType":"BACK_OFFICE_PAGE","compName":"bookings-bookings-list-page","aiContext":{"description":"Purpose: Wix Bookings appointments list \u2014 the master log of all bookings. View, filter, and manage individual bookings across all services: see upcoming and past appointments, check status (confirmed, pending, cancelled), contact clients, and take actions like reschedule or cancel.\\nAlso known as: bookings list, appointments, reservations list."}},"6fb8c87d-b838-47b2-b42c-2fbc20e407f8":{"compType":"BACK_OFFICE_PAGE","compName":"bookings-availability-management-page-lazy-component-id","aiContext":{"description":"Purpose: Bookings Availability Management page \u2014 the main view for managing staff/resource availability for bookable services. Users configure working hours, blocked times, and booking slots across staff members and resources.\\nAlso known as: availability settings, staff hours, booking availability, schedule management."}},"f92a0103-3623-425c-8c6c-7f5d551da75e":{"compType":"BACK_OFFICE_PAGE","compName":"c696eca6-7489-40ae-8c41-815cea571b53-alias-member-permissions-signup-login-settings","aiContext":{"description":"Purpose: Member Permissions \u2014 Signup & Login Settings tab, where the user configures how visitors register and log in: signup fields, login methods (email, social), and registration flow options. Distinct from the other Member Permissions tabs.\\nAlso known as: login settings, signup settings, registration, login options, sign-in settings, member login."}},"851096e5-ddde-4aaf-992b-38703c78a1a7":{"compType":"BACK_OFFICE_PAGE","compName":"wix-emails-automations-flow-pages-edit-campaignid","aiContext":{"description":"Purpose: Edit page for an email automation flow campaign (identified by campaignId). Users modify the content, trigger conditions, and settings of an existing automation-linked email campaign. Distinct from the standalone email editor \u2014 this is scoped to automations flows.\\nAlso known as: edit automation email, email automation editor, edit campaign flow.\\nDeep link: set `relativeUrl` to `{campaignId}/content/{language}` \u2014 the campaign GUID plus a required language code (e.g. `en`); both segments are required, so do not omit them."}},"bc51f16e-864e-4195-8252-833fc960a30a":{"compType":"BACK_OFFICE_PAGE","compName":"form-app-bm.pages.index","aiContext":{"description":"Purpose: Wix Forms index page listing all forms created for the site. Users see all forms at a glance, create new forms, and navigate to individual form details or settings.\\nAlso known as: forms list, all forms, my forms, forms dashboard, form submissions overview."}},"92c9fc07-c3d3-434d-8594-ca4685df1d66":{"compType":"BACK_OFFICE_PAGE","compName":"atlantic.pages.manage-languages","aiContext":{"description":"Purpose: Manage Languages page within Wix Multilingual (Atlantic). Users add, remove, reorder, and configure the languages available on their site, set the primary language, and toggle language visibility. Distinct from the translation editor; this controls which languages exist.\\nAlso known as: add language, remove language, language list, site languages."}},"a6a6a0ee-865f-43cc-a8f2-b50984f74457":{"compType":"BACK_OFFICE_PAGE","compName":"bookings-staff-edit-lazy-page","aiContext":{"description":"Purpose: Wix Bookings staff member editor \u2014 create or edit an individual team member. Set the staff member\'s name, bio, photo, assigned services, and working-hours schedule. Used when onboarding a new staff member or updating an existing one. Sibling: staff list shows all members; staff details is the read view.\\nDeep link: set `relativeUrl` to `{staffMemberId}` \u2014 a GUID (the bookings staff member id). Omit to open the default view."}},"f22259c8-e468-4bbf-90b2-7458fe82852e":{"compType":"BACK_OFFICE_PAGE","compName":"receipts-bm.pages.index","aiContext":{"description":"Purpose: Receipts main/index page. Entry point for the Receipts section \u2014 provides an overview of receipts activity and navigation to the receipts list and related payment records.\\nAlso known as: receipts home, receipts overview, payment receipts, receipt management."}},"3b96985e-a459-4972-94c3-63f038a73af2":{"compType":"BACK_OFFICE_PAGE","compName":"ecom-platform-dashboard-orders-details.order-details-page","aiContext":{"description":"Purpose: Order details page for a single eCommerce order. View full order summary, customer info, line items, payment status, fulfillment status, and timeline. Users can update fulfillment, issue refunds, add notes, and manage the order lifecycle.\\nAlso known as: order view, order info, specific order.\\nDeep link: set `relativeUrl` to `{id}` \u2014 a GUID (the eCommerce order id). Omit to open the default view."}},"78d84189-b964-4acf-a0b4-3f75a1e84159":{"compType":"BACK_OFFICE_PAGE","compName":"wix-code.logging-tools.wix-logs","aiContext":{"description":"Purpose: Live logs page for Wix Code (Velo) sites in Business Manager. Shows a real-time stream of logs generated by a site\'s code, and lets users connect the log stream to Google Operations or a custom HTTP endpoint.\\nAlso known as: live logs, site logs, site events, Velo logs, log viewer, Google Operations logs."}},"125b78e5-7189-473b-affd-763103b1b8d6":{"compType":"BACK_OFFICE_PAGE","compName":"wix-emails-module-pages-dashboard","aiContext":{"description":"Purpose: Wix Emails module main dashboard. Users get an overview of email marketing activity, recent campaigns, key metrics, and quick actions to create or manage campaigns.\\nAlso known as: email dashboard, email marketing home, email overview, campaigns dashboard."}},"1a2ebb61-3326-410b-baae-145c449a611c":{"compType":"BACK_OFFICE_PAGE","compName":"hopp-bm.pages.index","aiContext":{"description":"Purpose: Hopp by Wix link-in-bio page management. Users create and manage their Hopp profile \u2014 a mobile-friendly landing page with links, booking, and products, typically shared via social media bio.\\nAlso known as: Hopp, link in bio, social bio page, Hopp profile, link page."}},"ed0163bf-ddeb-4dbe-8042-648b44bcbaac":{"compType":"BACK_OFFICE_PAGE","compName":"Coupons","aiContext":{"description":"Purpose: The Coupons management page for Wix eCommerce. Users create, view, edit, enable/disable, and delete discount coupons (percentage, fixed-amount, or free-shipping).\\nAlso known as: coupons, promo codes, discount codes, vouchers, coupon list."}},"74ff0096-6e7f-4d40-9f72-e85a2a7d5726":{"compType":"BACK_OFFICE_PAGE","compName":"WIXSTORES_DASHBOARD_BACK_IN_STOCK.pages.index","aiContext":{"description":"Purpose: Wix Stores back-in-stock notifications management page. View and manage alerts sent to customers when out-of-stock products become available again. Track subscriber requests per product and trigger restock notifications.\\nAlso known as: back in stock alerts, restock notifications, out of stock alerts, notify me list."}},"f1bf0cfc-8141-428f-95db-ca2a76c9b02b":{"compType":"BACK_OFFICE_PAGE","compName":"pos-checkout.pages.index","aiContext":{"description":"Purpose: POS Checkout configuration or checkout flow page within the Wix Point of Sale section. Users set up or review the checkout experience for in-person transactions, including payment methods and receipt options.\\nAlso known as: POS checkout, point of sale checkout, in-person checkout settings, configure POS checkout."}},"946e4924-df4e-4550-a2a8-5e8292632e7a":{"compType":"BACK_OFFICE_PAGE","compName":"analytics-ng-bm.pages.overviews.sales","aiContext":{"description":"Purpose: Sales analytics overview page. Aggregates store and bookings revenue data \u2014 total sales, orders, average order value, top products, and refund rates.\\nAlso known as: sales report, revenue analytics, ecommerce stats, order analytics, sales performance."}},"d68e1be4-45a8-4bd5-8958-da21e6a1f6b2":{"compType":"BACK_OFFICE_PAGE","compName":"0845ada2-467f-4cab-ba40-2f07c812343d-alias-store-products","aiContext":{"description":"Purpose: Wix Stores product catalog list page. Displays all products in the store; users browse, search, filter, add new products, edit or delete existing ones, and manage inventory.\\nAlso known as: store, shop, product list, catalog, items, merchandise. Related: product detail editor, import products, store settings."}},"b8c96d90-95d6-57de-9a97-0d44c4dfaa96":{"compType":"BACK_OFFICE_PAGE","compName":"social-blog-writers","aiContext":{"description":"Purpose: Blog Writers (contributors) list page. Users see all people who have been given authorship or contributor access to the blog, and can invite or remove writers.\\nAlso known as: blog writers, blog contributors, blog authors, author list, contributor management, add writer."}},"151c444c-b0d5-49fa-8c75-2d19d8811e60":{"compType":"BACK_OFFICE_PAGE","compName":"analytics-ng-bm.pages.performance.insights","aiContext":{"description":"Purpose: Performance insights page. Surfaces AI-generated or rule-based actionable insights and recommendations based on the site\'s analytics data; highlights opportunities and anomalies to act on.\\nAlso known as: analytics insights, smart recommendations, performance tips, data insights, improvement suggestions."}},"c4230e27-212f-4aef-9c2f-401316242c8b":{"compType":"BACK_OFFICE_PAGE","compName":"storage-manager-bm-pages-index","aiContext":{"description":"Purpose: Storage manager page showing the site\'s media storage usage and quota. Users see how much storage is consumed, review usage breakdown, and manage or upgrade their storage plan.\\nAlso known as: storage, media storage, file storage, disk space, storage quota, media manager storage."}},"77e4c7f6-60a5-472a-9b55-d495dbe68701":{"compType":"BACK_OFFICE_PAGE","compName":"proposals-bm.pages.index","aiContext":{"description":"Purpose: Proposals list page. Users view, manage, and send business proposals to clients \u2014 browse all proposals, check status (draft, sent, accepted, declined), and open individual proposals.\\nAlso known as: proposals, client proposals, quotes list, business proposals, sent proposals, proposal manager."}},"2718bafd-5769-487e-b162-4b4d747edf89":{"compType":"BACK_OFFICE_PAGE","compName":"social-blog-pages-settings","aiContext":{"description":"Purpose: Blog Settings page. Users configure global blog options such as display name, SEO defaults, post layout preferences, social sharing, and member commenting permissions.\\nAlso known as: blog settings, blog configuration, blog preferences, set up blog."}},"1e2f3c58-cb45-4ce0-b7df-ef35c1d90af9":{"compType":"BACK_OFFICE_PAGE","compName":"lead-nurturing-services-list.pages.index","aiContext":{"description":"Purpose: Lead Nurturing services list page \u2014 shows all configured lead-nurturing services (automated follow-up campaigns linked to specific services). Users browse, add, edit, or delete services from here.\\nAlso known as: lead nurture services, nurturing campaigns list. Sibling to the individual service form page."}},"77f77e2b-56b6-4fe5-8011-ed1ebfd95c0b":{"compType":"BACK_OFFICE_PAGE","compName":"social-blog-bm-comments","aiContext":{"description":"Purpose: Blog Comments management page in Business Manager. Users review, moderate, approve, or delete reader comments across all blog posts.\\nAlso known as: blog comments, moderate comments, comment moderation, reader comments, approve comments."}},"bf22793f-4ffa-4ae4-b1c4-3d3e022fc65e":{"compType":"BACK_OFFICE_PAGE","compName":"wix-donations-dashboard.pages.campaign.new","aiContext":{"description":"Purpose: Create new donation campaign page. Users define a new fundraising campaign by entering a name, goal amount, description, and other settings before publishing.\\nAlso known as: new donation campaign, create campaign, start fundraiser, add donation campaign, new fundraising campaign."}},"0c7a26e9-553e-4ed3-a89c-136ac5ead88b":{"compType":"BACK_OFFICE_PAGE","compName":"analytics-stores-bm.pages.overviews.store","aiContext":{"description":"Purpose: Store overview page inside Wix Stores analytics. Shows aggregated eCommerce metrics: total sales, orders, top products, conversion funnel, and revenue trends. Users monitor store health, compare periods, and drill into product or sales performance.\\nAlso known as: store analytics, shop overview, ecommerce stats, sales dashboard."}},"ab4a2cc2-7733-4884-9d11-0e9e92bfd699":{"compType":"BACK_OFFICE_PAGE","compName":"community-pages-index","aiContext":{"description":"Purpose: Community overview in Business Manager \u2014 the landing hub for the site\'s community apps (such as Groups, Events, Blog, Video Library, Online Programs, Chat, and Comments). Shows installed apps and recommends more, so site owners can connect with members, grow their audience, and follow guided steps to build an engaged community. Entry point to the individual community apps rather than a single app\'s management screen.\\nAlso known as: community, community overview, community hub, community apps, members community, engage community."}},"a1171a78-cdc7-4149-a531-72dbddeffa4b":{"compType":"BACK_OFFICE_PAGE","compName":"site-member-access-page","aiContext":{"description":"Purpose: Site Member Access settings page for controlling who can access restricted site pages and members-only content. Users set access rules, assign member roles, and manage permissions for gated pages.\\nAlso known as: member permissions, page access, restrict page, members-only settings, access control."}},"5756be67-8466-4d11-9980-483a1b4cc985":{"compType":"BACK_OFFICE_PAGE","compName":"lazy-events-drafts","aiContext":{"description":"Purpose: Draft Events page in the Wix Events back-office. Shows all unpublished (draft) events the user has created but not yet published. Users review, edit, and publish drafts from here.\\nAlso known as: event drafts, unpublished events, saved events. Sibling to the Published Events and Past Events pages."}},"9c24e0ea-a935-49a1-853b-c3fcd556b427":{"compType":"BACK_OFFICE_PAGE","compName":"wixstores-dashboard-categories.pages.category.id","aiContext":{"description":"Purpose: Wix Stores individual product category editor. Edit a specific category \u2014 update its name, description, image, SEO settings, and the products it contains. Navigated to from the categories list.\\nAlso known as: edit category, category settings, category details, update category.\\nDeep link: set `relativeUrl` to `{categoryId}` \u2014 a GUID (the Wix Stores category id). Omit to open the default view."}},"e8f88183-6d75-4b50-a6c5-54252f489365":{"compType":"BACK_OFFICE_PAGE","compName":"privacy-center","aiContext":{"description":"Purpose: Privacy Center management page for a Wix site. Users configure GDPR and privacy settings here: manage cookie consent banners, handle data subject access requests (DSAR), control data retention policies, and review the site\'s privacy policy setup.\\nAlso known as: GDPR settings, cookie consent, data privacy, privacy policy, data requests, compliance center."}},"7f43cf15-e14a-48f7-a7fa-9d0d1b1a6f02":{"compType":"BACK_OFFICE_PAGE","compName":"ecom-dashboard-tax.pages.index","aiContext":{"description":"Purpose: eCommerce tax settings page. Configure tax rules, tax groups, and regional tax rates for your online store. Users set up automatic tax calculation, add manual tax overrides, and manage tax-exempt categories.\\nAlso known as: tax configuration, store taxes, sales tax setup, VAT settings."}},"24cf4dd7-b4e1-4e9e-9773-f56db185710f":{"compType":"BACK_OFFICE_PAGE","compName":"analytics-ng-bm.pages.performance.reliability","aiContext":{"description":"Purpose: Site reliability analytics page. Monitors uptime, error rates, page load times, and other technical health indicators; users identify performance degradations or outages impacting visitors.\\nAlso known as: uptime, site health, reliability report, error monitoring, technical performance, site speed."}},"8bae1213-e243-4cd5-910b-9c3d4b6c0750":{"compType":"BACK_OFFICE_PAGE","compName":"rise-client-dashboard.pages.gift-card-sales","aiContext":{"description":"Purpose: Gift card sales analytics page within the Wix Rise / Gift Cards dashboard. Shows sales performance, revenue, and redemption data for gift cards sold. Users come here to review gift card revenue, track redemptions, and analyze sales trends.\\nAlso known as: gift card analytics, gift card revenue, gift card sales report, Rise sales.\\nDeep link: set `relativeUrl` to `{giftCardId}` \u2014 a gift card id GUID (path segment split out as detailedGiftCardId). Omit to open the default view."}},"2a98c3cb-ebde-46a2-a7c4-b3c2d11edc0a":{"compType":"BACK_OFFICE_PAGE","compName":"promote-seo-verification","aiContext":{"description":"Purpose: SEO Site Verification page. Users verify ownership of their site with external search consoles and webmaster tools (Google Search Console, Bing Webmaster Tools, Pinterest, etc.) by adding verification codes or meta tags.\\nAlso known as: verify site, Google Search Console, Bing verification, site ownership verification, webmaster tools, verify with Google."}},"f2c85ff2-21c8-4afd-b7a0-61571f542656":{"compType":"BACK_OFFICE_PAGE","compName":"stores-channels-home-page-app.pages.index","aiContext":{"description":"Purpose: Wix Stores home-page sales channel \u2014 lets merchants feature and sell products directly through their site\'s homepage channel. Users configure the channel, manage connected products, and review channel status.\\nAlso known as: homepage channel, stores homepage, front page sales channel."}},"4e478999-0c3c-460f-80d7-92867a182df5":{"compType":"BACK_OFFICE_PAGE","compName":"wix-donations-dashboard.pages.index","aiContext":{"description":"Purpose: Wix Donations dashboard \u2014 the main index page listing all donation campaigns. Users view campaign summaries, donation totals, statuses, and navigate to individual campaigns or create a new one.\\nAlso known as: donations, fundraising dashboard, donation campaigns list, my campaigns, fundraising overview."}},"e2b03626-0f21-4ee4-b542-30a42bfe00d6":{"compType":"BACK_OFFICE_PAGE","compName":"promote-seo-redirects-bm-component","aiContext":{"description":"Purpose: SEO URL Redirects management page. Users create, edit, and delete URL redirects for their site \u2014 map old URLs to new ones to help preserve SEO signals and prevent broken links.\\nAlso known as: URL redirects, redirect manager, 301 redirect, broken link fix, redirect old pages, SEO redirects."}},"99a3a241-9d0a-4bc1-b3d3-88c8ab745ff4":{"compType":"BACK_OFFICE_PAGE","compName":"PRICING_PLANS.pages.new","aiContext":{"description":"Purpose: New Pricing Plans plan creation page. Users define and publish a brand-new membership or subscription plan from scratch. Distinct from the plan edit page.\\nAlso known as: create pricing plan, new plan, add subscription plan, new membership plan, set up pricing plan."}},"721868b6-1d4d-4a40-a876-786f6cbfffcc":{"compType":"BACK_OFFICE_PAGE","compName":"promote-seo-tools","aiContext":{"description":"Purpose: Legacy SEO Tools entry point. This page has no tools UI of its own \u2014 it immediately redirects to the SEO home/dashboard (PromoteSeoHome). Treat it as a legacy redirect entry rather than a destination for specific SEO tools.\\nAlso known as: SEO tools, SEO tools redirect, legacy SEO tools entry."}},"c02c18c1-cc11-44ff-8a09-a98736d14d11":{"compType":"BACK_OFFICE_PAGE","compName":"analytics-ng-bm.pages.overviews.marketing","aiContext":{"description":"Purpose: Marketing analytics overview page. Reports on campaign performance \u2014 email clicks, social referrals, paid ads attribution, coupon usage, and marketing-channel revenue.\\nAlso known as: marketing report, campaign analytics, ads performance, promo stats, marketing insights."}},"bc0f4f57-96a4-4687-aeeb-10dabf599948":{"compType":"BACK_OFFICE_PAGE","compName":"c696eca6-7489-40ae-8c41-815cea571b53-alias-member-permissions-roles","aiContext":{"description":"Purpose: Member Permissions \u2014 Roles tab, where the user creates, edits, and deletes custom member roles and configures what each role can access. Use this to define role names and permissions. Distinct from the Members tab (individual member management).\\nAlso known as: roles, member roles, custom roles, access roles, permissions roles."}},"8213d705-adf4-48a6-b18a-0f63da180bec":{"compType":"BACK_OFFICE_PAGE","compName":"atlantic.pages.index","aiContext":{"description":"Purpose: Wix Multilingual (Atlantic) main index page \u2014 the landing screen for managing site translations. Users see a summary of translated and untranslated content, choose languages to translate, and navigate to translation tasks.\\nAlso known as: multilingual home, translations overview, translate my site, language management home."}},"c3ad65e1-0b0f-4da9-a8a3-6025c321da50":{"compType":"BACK_OFFICE_PAGE","compName":"loyalty-bm-pages-index","aiContext":{"description":"Purpose: Loyalty Program overview / landing page in the back-office. Entry point for the Wix Loyalty program feature; displays program status, points summary, and quick-action links. Users land here to get a high-level view of their loyalty setup.\\nAlso known as: loyalty dashboard, rewards program overview, points program home."}},"297b8d12-cf52-4f0d-9bb2-4e2b4a4af782":{"compType":"BACK_OFFICE_PAGE","compName":"wix-emails-module-pages-onboarding","aiContext":{"description":"Purpose: Email marketing onboarding page for new users setting up Wix Emails for the first time. Users complete initial setup steps, connect their sender domain, and get oriented to email campaign features.\\nAlso known as: email setup, get started with emails, email marketing intro, activate emails."}},"fba6179c-6d3a-4ff4-9d48-9209b0de5d19":{"compType":"BACK_OFFICE_PAGE","compName":"loyalty-bm-pages-welcome","aiContext":{"description":"Purpose: Loyalty Program welcome / onboarding page \u2014 shown when a user first sets up or activates their Wix Loyalty program. Guides the user through initial program configuration steps.\\nAlso known as: loyalty setup, get started with loyalty, rewards program onboarding. Distinct from the ongoing management and overview pages."}},"72527aad-8bfc-4a25-8ae5-205279af1a7e":{"compType":"BACK_OFFICE_PAGE","compName":"receipts-bm-pages-list","aiContext":{"description":"Purpose: Receipts list page. Users browse and manage all issued receipts for payments collected through the site \u2014 filter by date or status, view individual receipt details, and download or resend receipts to customers.\\nAlso known as: receipts, payment receipts, issued receipts, receipt history, transaction receipts."}},"44e96693-6326-4574-92d0-f8bc532f7836":{"compType":"BACK_OFFICE_PAGE","compName":"frontdesk-support-agent-web-onboarding.pages.frontdesk-assistant","aiContext":{"description":"Purpose: Frontdesk AI support assistant onboarding page. Guides business owners through setting up an AI-powered front-desk virtual agent that handles customer inquiries.\\nAlso known as: frontdesk assistant setup, AI receptionist onboarding, customer support bot, virtual assistant setup, automated support agent."}},"06313e49-80f7-498e-99cd-312eab83f391":{"compType":"BACK_OFFICE_PAGE","compName":"social-blog-tags","aiContext":{"description":"Purpose: Blog Tags management page. Users create and manage tags that can be applied to posts for finer-grained filtering beyond categories.\\nAlso known as: blog tags, post tags, add tags, manage tags, tag list."}},"e96a4137-cf9d-42ba-96c2-b583fce6f00b":{"compType":"BACK_OFFICE_PAGE","compName":"ping-settings-client.settings.notifications","aiContext":{"description":"Purpose: Notification settings page for the Ping (Wix notifications) service. Users configure which business events trigger push, email, or in-app notifications and manage alert preferences.\\nAlso known as: notification settings, alert preferences, ping settings, manage notifications, turn off notifications, notification center settings."}},"26b6472d-67f1-4fb3-bab3-13f3d0bc9dd9":{"compType":"BACK_OFFICE_PAGE","compName":"cms-web-bm-app.pages.index","aiContext":{"description":"Purpose: Content Manager (CMS) index page in Business Manager \u2014 the main landing page for the Wix CMS, listing all content collections for the site. Use this to browse, create, or open content collections and their data entries.\\nAlso known as: CMS, content manager, database, collections, content collections, data manager."}},"e0108e9d-6a07-4540-9c9f-ea8a4a75087f":{"compType":"BACK_OFFICE_PAGE","compName":"crm-financial.pages.invoice.form","aiContext":{"description":"Purpose: The Invoice creation/editing form in Wix Finances. Users create a new invoice or edit an existing one \u2014 adding line items, client details, due dates, taxes, and notes \u2014 then send or save it.\\nAlso known as: create invoice, new invoice, invoice form, edit invoice, billing form.\\nDeep link: set `relativeUrl` to `new?id={invoiceId}` \u2014 an invoice id GUID (read from the `id` query param in edit mode). Omit to open the default view."}},"1267cce6-9f18-4e32-9bcf-41860af3f52d":{"compType":"BACK_OFFICE_PAGE","compName":"bookings-resource-types-list-page","aiContext":{"description":"Purpose: Wix Bookings resource types list. View and manage resource categories (e.g. rooms, equipment, courts) that can be assigned to services alongside staff. Add new resource types or select one to configure. Distinct from the staff list.\\nAlso known as: resources, resource categories, assets."}},"b5dfad3d-0bbb-4e8a-8630-c70e0abc4ae4":{"compType":"BACK_OFFICE_PAGE","compName":"restaurants-menus-management-items","aiContext":{"description":"Purpose: Restaurant menus \u2014 items management page. Users add, edit, and organize individual menu items (dishes): set names, descriptions, prices, images, dietary labels, and availability.\\nAlso known as: menu items, add dish, edit food item, restaurant menu items, food catalog, menu item management."}},"046d53be-233c-4e48-b345-7fb7c833a3f3":{"compType":"BACK_OFFICE_PAGE","compName":"portfolio-pages-integrations","aiContext":{"description":"Purpose: Integrations settings page for the Portfolio feature. Users connect or disconnect third-party integrations (e.g. social sharing, external services) that surface or sync portfolio content.\\nAlso known as: portfolio integrations, connect portfolio, portfolio settings integrations, portfolio plugins."}},"9c659562-3e73-40dc-9fa5-5515d7a233ce":{"compType":"BACK_OFFICE_PAGE","compName":"referrals-bm.pages.index","aiContext":{"description":"Purpose: Referrals program main page. Users manage their customer referral program here: view referred customers, track rewards, configure referral incentives, and monitor program performance.\\nAlso known as: referrals, referral program, refer a friend, referral rewards, customer referrals, referral dashboard."}},"407c7949-3c56-4ad2-8153-f168d08bce99":{"compType":"BACK_OFFICE_PAGE","compName":"MEMBERS_ACCOUNT_BM.pages.index","aiContext":{"description":"Purpose: Members Account page \u2014 the main back-office page for managing site members. Users view the full member list, search for specific members, edit profiles, change roles, block or remove members.\\nAlso known as: members list, site members, manage members, member accounts."}},"7dfef941-fc44-4d51-bb91-ffb0fc97bae0":{"compType":"BACK_OFFICE_PAGE","compName":"social-blog-pages-edit-category","aiContext":{"description":"Purpose: Edit Blog Category page \u2014 a form for modifying a single blog category\'s name, description, and associated posts. Distinct from the category list page; users land here to update one specific category.\\nAlso known as: edit category, rename category, update blog category.\\nDeep link: set `relativeUrl` to `{categoryId}` or `{categoryId}/{locale}` \u2014 a GUID (the blog category id) and optional locale code (e.g. \'en\', \'fr\') for multilingual categories. The categoryId is required; if omitted, the page redirects to the categories list."}},"15520012-c3d3-4d78-81c4-3d3b846e8634":{"compType":"BACK_OFFICE_PAGE","compName":"referrals-bm-pages-welcome","aiContext":{"description":"Purpose: Referrals program welcome / intro page. Users land here when first accessing the referrals feature \u2014 explains how the referral program works and guides them through setup before they start managing referrals.\\nAlso known as: referrals welcome, referral program intro, set up referrals, referral onboarding."}},"5adf8453-2f21-4c3c-843e-d62be5a16000":{"compType":"BACK_OFFICE_PAGE","compName":"ecom-platform-checkout-composer.pages.index","aiContext":{"description":"Purpose: Checkout composer / checkout customization settings page. Configure the checkout flow, add custom fields, set payment and shipping options, and control the buyer checkout experience.\\nAlso known as: checkout settings, checkout design, checkout builder, customize checkout."}},"79dbb935-d823-4feb-9272-ef2cbcf2aafd":{"compType":"BACK_OFFICE_PAGE","compName":"subscriptions-bm","aiContext":{"description":"Purpose: Subscriptions list page in Business Manager. Shows all recurring subscription plans sold to site members/customers, including plan status, subscribers, and billing details. Users browse, search, and manage active subscriber records.\\nAlso known as: subscriptions, member subscriptions, recurring plans, subscriber list, pricing plans subscribers.\\nDeep link: set `relativeUrl` to `{id}` \u2014 a subscription id GUID. Omit to open the default view."}},"7c16a0db-097f-410b-8da2-a4880491e904":{"compType":"BACK_OFFICE_PAGE","compName":"bookings-booking-checkout-settings-pages-forms-manager","aiContext":{"description":"Purpose: Wix Bookings checkout form manager for booking intake. View and manage the intake forms attached to services \u2014 add, remove, or reorder fields that customers fill in during checkout. Use this to edit booking forms, customize required fields, or set up intake questions. Distinct from the booking flow settings; this is specifically the forms/fields layer."}},"967cae3e-62db-4a8d-a74d-a89a234654c2":{"compType":"BACK_OFFICE_PAGE","compName":"ecom-fulfillment-services-pages-fulfillment-services","aiContext":{"description":"Purpose: Fulfillment services management page for the eCommerce store. Lists connected third-party fulfillment providers and lets users add, configure, or remove fulfillment integrations.\\nAlso known as: fulfillment providers, shipping fulfillment, 3PL integrations, fulfillment settings."}},"8846e381-ec81-4e91-a06b-99eecf509692":{"compType":"BACK_OFFICE_PAGE","compName":"PRICING_PLANS.pages.edit","aiContext":{"description":"Purpose: Edit page for an existing Pricing Plans plan. Users modify a plan\'s name, pricing, billing cycle, benefits, and availability. Distinct from the new-plan creation page.\\nAlso known as: edit pricing plan, update plan, modify subscription plan, change plan details, pricing plan editor.\\nDeep link: set `relativeUrl` to `{planId}` \u2014 a GUID (the pricing plan id). Omit to open the default view."}},"ccf2fe64-86c2-44a3-8e97-eed943c49b58":{"compType":"BACK_OFFICE_PAGE","compName":"challenges-web-business-manager","aiContext":{"description":"Purpose: Online Programs \u2014 entry point for the Wix Online Programs back-office app (formerly Challenges), where a site owner creates and monetizes online courses and step-by-step programs. Programs can be self-paced or scheduled. Use this to start a new program (from scratch, from a template, or with the built-in AI/Lumo builder) or to open the Online Programs section. Leads into the program editor to build sections and steps (including quizzes and video), set pricing (one-time payment or pricing plan/subscription) and visibility, manage participants and track progress, assign instructors, connect a community group and AI Tutor, issue certificates and rewards, and send notifications. Currently opens the Online Programs list (Published, Draft, Archived).\\nAlso known as: online programs, programs, courses, challenges, create program, new online program, program builder, add course, start a program.\\nDeep link: set `relativeUrl` to `lumo` to open the AI (Lumo) program builder, `program-templates` for the templates gallery, or `create-program-from-scratch` to start from scratch."}},"2bb398d9-3b0e-4c97-af93-8ff6452e33b1":{"compType":"BACK_OFFICE_PAGE","compName":"proactive-marketing-assistant-page","aiContext":{"description":"Purpose: Proactive Marketing Assistant main workspace (PMA). Users interact with the AI marketing assistant here: review AI-generated marketing suggestions, approve or dismiss campaigns, track assistant activity, and manage ongoing marketing tasks.\\nAlso known as: marketing AI assistant, PMA dashboard, AI marketing suggestions, marketing autopilot. See also: the onboarding index for first-time setup."}},"33aceb11-ee9e-4b85-bcf0-a356bbde1f74":{"compType":"BACK_OFFICE_PAGE","compName":"session-recordings","aiContext":{"description":"Purpose: Session Recordings page in Business Manager (Wix Analytics / Visitor Analytics). Lets the site owner play back recorded visitor browsing sessions to understand user behavior and UX issues. Users come here to watch session replays, analyze visitor paths, identify where users struggle.\\nAlso known as: visitor recordings, session replay, heatmap recordings, visitor sessions, replay recordings."}},"ceb6dda8-bce4-4b46-b649-a65b53d58cab":{"compType":"BACK_OFFICE_PAGE","compName":"wix-emails-automations-flow-pages-preview-campaignid","aiContext":{"description":"Purpose: Preview page for an email automation flow campaign (identified by campaignId). Users see a read-only preview of how an automation-triggered email will look before sending or activating.\\nAlso known as: preview automation email, email preview, campaign preview, automation flow email preview.\\nDeep link: set `relativeUrl` to `{campaignId}/content/{language}` \u2014 the campaign GUID plus a required language code (e.g. `en`); both segments are required, so do not omit them."}},"84c40cf0-2ff9-49b8-b7c9-17e5c7316200":{"compType":"BACK_OFFICE_PAGE","compName":"pos-bm.pages.index","aiContext":{"description":"Purpose: Point of Sale (POS) main dashboard page within Business Manager. Users view POS terminal activity, sales summaries, connected devices, and navigate to POS-related settings.\\nAlso known as: POS dashboard, point of sale, in-person sales, POS home, retail dashboard, POS overview."}},"d033dcbc-2f52-4c9d-a502-80d033b67422":{"compType":"BACK_OFFICE_PAGE","compName":"challenges-web-business-manager-list","aiContext":{"description":"Purpose: Online Programs list \u2014 the back-office section for Wix Online Programs (formerly Challenges), where a site owner builds and manages online courses and step-by-step programs that help members achieve their goals. Browse every program across Published, Draft, and Archived tabs with participant counts. Search and filter by schedule (self-paced or scheduled), payment type, visibility, and category; sort by title or date. Create a new program (from scratch, from a template, or with the built-in AI/Lumo program builder) and act on existing ones: publish, unpublish, duplicate, end, archive, delete, or create a coupon. Opening a program leads to its editor for content and participants. Use this to view, search, or manage all online programs.\\nAlso known as: online programs, programs, courses, challenges, program list, all programs, manage programs, view programs, my courses, fitness programs, coaching programs, self-paced courses.\\nDeep link: set `relativeUrl` to `{programId}/program/overview` to open one specific program (the program id is a GUID). Switch the last segment for a specific area: `{programId}/program/content` (sections and steps), `{programId}/program/participants`, `{programId}/program/engagement`, `{programId}/program/settings`. Other per-program areas: `{programId}/ai-tutor` (AI Tutor), `{programId}/notification-settings` (participant notifications). To create a program, set `relativeUrl` to `lumo` (AI/Lumo builder), `program-templates` (templates gallery), or `create-program-from-scratch` (from scratch). Omit `relativeUrl` to open the program list."}},"135f0c27-4fb9-453d-8479-7f8762227234":{"compType":"BACK_OFFICE_PAGE","compName":"contacts-import-page","aiContext":{"description":"Purpose: The Contacts Import page for bulk-importing contacts into your Wix CRM. Users upload a CSV or spreadsheet file, map columns to contact fields, and confirm the import to add multiple contacts at once. Also reached when users say: import contacts, upload contacts list, bulk add contacts, CSV import."}},"9fb370d3-4ce7-40a4-a843-4e04e5106f49":{"compType":"BACK_OFFICE_PAGE","compName":"lead-nurturing-service-form.pages.index","aiContext":{"description":"Purpose: Lead Nurturing service form page \u2014 a form interface for configuring or viewing a single lead-nurturing service (e.g. an automated follow-up or drip campaign tied to a specific service offering). Users fill in service details and save the configuration.\\nAlso known as: lead nurture form, service nurturing setup. Sibling to the lead-nurturing services list page.\\nDeep link: set `relativeUrl` to `?serviceId={serviceId}` \u2014 a Wix Services service id GUID (passed as the serviceId query param). Omit to open the default view."}},"3747084e-774c-4859-b3f0-adb496ff999e":{"compType":"BACK_OFFICE_PAGE","compName":"wix-video-library.channels","aiContext":{"description":"Purpose: Wix Video library \u2014 Channels management page. Create and manage video channels that group your videos for subscribers. Control channel settings, visibility, and membership.\\nAlso known as: video channels, Wix Video channels, my channels, channel list, manage channels."}},"0b3f3632-04c2-4f36-8bc3-7f71012ff6a6":{"compType":"BACK_OFFICE_PAGE","compName":"pipelines-page.pages.index","aiContext":{"description":"Purpose: Main list/index page for the Wix CRM Pipelines feature. Users view all sales or CRM pipelines, see deals/leads per stage, and navigate into individual pipeline boards.\\nAlso known as: pipelines, deal pipelines, sales pipeline, CRM pipeline list, lead pipeline, show pipelines."}},"e1a20a83-1908-4bae-9214-b9e26e6fda2a":{"compType":"BACK_OFFICE_PAGE","compName":"wix-code-platform-visibility-bm.pages.index","aiContext":{"description":"Purpose: Monitoring dashboard for Wix Code (Velo) sites in Business Manager. Shows data request and backend request statistics, errors, and content collection storage usage, helping users spot performance issues on their site.\\nAlso known as: monitoring dashboard, site monitoring, data requests, backend requests, storage usage, performance monitoring."}},"8454e8a0-5684-4331-9d4a-e4873467553a":{"compType":"BACK_OFFICE_PAGE","compName":"ecom-platform-dashboard-orders-draft.draft-order-page","aiContext":{"description":"Purpose: Create-order page \u2014 where a merchant manually creates a new order via the draft-order mechanism. Add line items (from catalogs or custom), adjust their price and quantity, add fees and discounts, set the delivery method, and set the contact associated with the order. Shares its UI with the edit-order page (the difference is the create-vs-edit action).\\nAlso known as: create order, new order, manual order, draft order, add order manually.\\nDeep link: set `relativeUrl` to `{draftOrderId}` \u2014 a GUID (the draft order id); omit to start a new order."}},"cc53133b-a290-4f32-8d0f-f890fb8de73f":{"compType":"BACK_OFFICE_PAGE","compName":"wix-emails-module-pages-edit-campaignid","aiContext":{"description":"Purpose: Edit page for a specific email campaign (by campaignId) in the Wix Emails module. Users modify email content, design, subject line, and recipient settings using the email editor. Distinct from the automation-flow edit page \u2014 this is for standalone email campaigns.\\nAlso known as: edit email campaign, email editor, campaign editor, edit newsletter.\\nDeep link: set `relativeUrl` to `{campaignId}` \u2014 the campaign GUID; required, as the composer loads one specific campaign and errors on a missing or invalid id."}},"bdf1cafc-0d34-4185-9806-8f8509269c6b":{"compType":"BACK_OFFICE_PAGE","compName":"events-categories","aiContext":{"description":"Purpose: Events categories management page. Create and manage categories used to organize Wix Events on the storefront. Users add, rename, reorder, or delete event categories/tags.\\nAlso known as: event categories, event tags, event groups, organize events."}},"f481dd4f-e83a-58b5-af42-0d485a28807b":{"compType":"BACK_OFFICE_PAGE","compName":"social-blog-writers-edit","aiContext":{"description":"Purpose: Edit Blog Writer page \u2014 a detail form for updating a specific writer\'s display name, bio, and profile image. Distinct from the writers list; users land here to modify one contributor\'s profile.\\nAlso known as: edit writer, edit author, update blog contributor, writer profile."}},"aaec3e48-0122-4fb4-ae57-dc1ba2cd05c1":{"compType":"BACK_OFFICE_PAGE","compName":"wix-ai-assistant-client-bm.pages.index","aiContext":{"description":"Purpose: Wix AI Assistant client page embedded in Business Manager. Users interact with the AI-powered assistant to get help, ask questions, or automate tasks across their business.\\nAlso known as: AI assistant, Wix assistant, AI chat, virtual assistant, Wix AI, chatbot."}},"5b41c409-a41a-4b93-b650-5793ed5a4e39":{"compType":"BACK_OFFICE_PAGE","compName":"olo-settings-lobby","aiContext":{"description":"Purpose: Online Ordering settings lobby \u2014 the main settings hub for Wix Restaurants Online Ordering. Provides navigation to all OLO configuration sections such as menus, fulfillment, payments, and hours. Use this as the starting point for configuring restaurant online ordering.\\nAlso known as: online ordering settings, restaurant settings, OLO lobby."}},"e4d65aa4-30ba-4700-ad47-28765d4cf3bc":{"compType":"BACK_OFFICE_PAGE","compName":"table-reservations-bm-pages-table-reservations","aiContext":{"description":"Purpose: Table reservations management page in Business Manager. Restaurant or venue owners view, confirm, modify, and cancel table bookings, manage walk-ins, and configure reservation settings.\\nAlso known as: table reservations, restaurant bookings, reserve a table, booking management, dining reservations."}},"681cbbb9-800c-414f-856a-ad4be4e1b296":{"compType":"BACK_OFFICE_PAGE","compName":"social-blog-monetization","aiContext":{"description":"Purpose: Blog Monetization settings page. Users configure paid subscriptions, gated posts, or other revenue options for their blog.\\nAlso known as: blog monetization, paid blog, blog subscriptions, blog revenue, earn from blog, paywall."}},"0a9d40e9-a71b-41d7-b5d6-69dbd54af4ac":{"compType":"BACK_OFFICE_PAGE","compName":"Marketplace - Wix Payments Transactions","aiContext":{"description":"Purpose: Wix Payments Transactions page within the Marketplace section of Business Manager. Lists all payment transactions processed through Wix Payments for the site. Users search, filter, and inspect individual transaction records.\\nAlso known as: payments transactions, Wix Pay transactions, payment history, transaction log."}},"04c7e480-f1ad-4742-81f6-ac0edfd8a350":{"compType":"BACK_OFFICE_PAGE","compName":"social-groups-dashboard","aiContext":{"description":"Purpose: Wix Groups dashboard (overview) in Business Manager \u2014 the hub for managing all member community groups on the site. See the full group list with member counts and activity, create a group, handle pending group-creation and membership requests, set up group automations, and review engagement suggestions. Select any group to manage its info, members, feed, comments, events, tabs, topics, and settings.\\nAlso known as: groups, community groups, member groups, manage groups, groups overview, social groups, clubs."}},"96a68c65-c684-46ef-91fb-2906316193f5":{"compType":"BACK_OFFICE_PAGE","compName":"papyrus-pages-params","aiContext":{"description":"Purpose: Papyrus PDF document template rendering page. Renders PDF/document templates (tickets, certificates, invoices, etc.) for Wix applications. Users come here to view rendered documents generated from configured templates. This is the document viewer and template renderer, not a SEO/routing configuration page.\\nAlso known as: PDF viewer, document template renderer, ticket viewer, certificate viewer.\\nDeep link: set `relativeUrl` to `{params}` \u2014 catch-all path segments identifying the document type and parameters to render. Omit to open the default view."}},"a33e8b50-dd3e-47c3-8605-cf972d0142dc":{"compType":"BACK_OFFICE_PAGE","compName":"analytics-ng-bm.pages.performance.benchmarks","aiContext":{"description":"Purpose: Performance benchmarks page. Compares the site\'s key metrics (traffic, conversion, revenue) against industry averages or peer sites; helps users understand how they rank relative to competitors.\\nAlso known as: benchmarks, industry comparison, competitor comparison, how do I compare, performance ranking."}},"3e6d608b-bbc2-4e72-a1ef-4d441bb113ad":{"compType":"BACK_OFFICE_PAGE","compName":"bookings-staff-details-lazy-component-id","aiContext":{"description":"Purpose: Wix Bookings staff member creation form. Step-by-step form to create a new staff member. Set the staff member\'s name, bio, photo, assigned services, and working-hours schedule. Used when onboarding a new team member.\\nAlso known as: add staff member, new staff member, create staff.\\nDeep link: set `relativeUrl` to `create` to open the new staff member form. Omit to open the default view."}},"809a3e90-0a25-402d-a1aa-77529dfaa935":{"compType":"BACK_OFFICE_PAGE","compName":"Discount rules","aiContext":{"description":"Purpose: The Discount Rules list page for Wix eCommerce. Users view and manage automatic discount rules that apply discounts to orders based on conditions (cart total, specific products, customer segments) without requiring a coupon code.\\nAlso known as: discount rules, automatic discounts, order discounts, pricing rules."}},"1ad58cde-33b2-4269-a4ea-6a5bc036e10d":{"compType":"BACK_OFFICE_PAGE","compName":"bookings-email-sms-reminder-settings","aiContext":{"description":"Purpose: Wix Bookings email and SMS reminder settings. Configure automated reminders sent to clients before their appointments \u2014 set timing, message content, and which channels (email vs SMS) to use. Also covers follow-up notifications.\\nAlso known as: booking reminders, appointment notifications, client alerts."}},"1e277402-57d7-4630-8419-88555f9e4b0a":{"compType":"BACK_OFFICE_PAGE","compName":"member-permissions-roles-manage-permissions","aiContext":{"description":"Purpose: Manage Role Permissions page \u2014 a detailed configuration screen for editing the capabilities of a specific member role. Users toggle individual permissions (page access, content actions, etc.) for the selected role.\\nAlso known as: edit role, role permissions settings, manage role access. Sibling to the top-level Member Permissions list page."}},"2c7daf4b-dbe7-4e00-9ffd-9b44b1884507":{"compType":"BACK_OFFICE_PAGE","compName":"restaurants-orders-prep-board.pages.index","aiContext":{"description":"Purpose: Restaurant orders preparation board (kitchen display / prep view) for Wix Restaurants. Shows incoming orders grouped by status so kitchen and front-of-house staff can track and advance order fulfillment. Users come here to manage live orders, mark orders as in-progress or ready, and coordinate kitchen workflow.\\nAlso known as: kitchen board, prep board, orders board, live orders, kitchen display."}},"e5406047-3e4a-4fab-8480-b9bc1905e8de":{"compType":"BACK_OFFICE_PAGE","compName":"rnp-pages-change-role-business-manager","aiContext":{"description":"Purpose: Change role page within Roles & Permissions (RNP) in Business Manager. Modify the role assigned to an existing collaborator on the site. Users come here after selecting a collaborator to update their role.\\nAlso known as: change collaborator role, edit role, update role, reassign role.\\nDeep link: set `relativeUrl` to `{collaboratorId}` \u2014 a GUID (the collaborator id). Omit to open the default view."}},"4c71ec57-3f74-421f-adf6-886fe614e365":{"compType":"BACK_OFFICE_PAGE","compName":"bm-settings-web-performance.pages.index","aiContext":{"description":"Purpose: Web Performance settings page in Business Manager. Lets users configure site-level performance optimizations such as lazy loading, caching rules, and resource hints. Distinct from the Analytics Site Speed page (which shows metrics); this page controls the settings that affect speed.\\nAlso known as: performance settings, speed settings, web performance config, site optimization settings."}},"e293dfec-0359-4155-b618-b5e6ff62fc63":{"compType":"BACK_OFFICE_PAGE","compName":"promote-seo-sitemap","aiContext":{"description":"Purpose: SEO Sitemap page. Users view and open the generated `sitemap.xml` that search engines use to discover site pages, see indexability/publish guidance, and access related FAQ/help links. It does not manage included/excluded pages, regenerate the sitemap, or submit it to search consoles from this page.\\nAlso known as: sitemap, XML sitemap, sitemap.xml, sitemap page."}},"4576d2f4-7da6-4ad1-ad51-418e09847e34":{"compType":"BACK_OFFICE_PAGE","compName":"wix-code-site-monitoring-bm.pages.index","aiContext":{"description":"Purpose: Live logs page for Wix Code (Velo) sites in Business Manager. Shows a real-time stream of logs generated by a site\'s code, and lets users connect the log stream to Google Operations or a custom HTTP endpoint. Deprecated: this is the older version of this page and has been replaced by the newer Logs page.\\nAlso known as: live logs, site logs, site events, Velo logs, log viewer, Google Operations logs."}},"41af28bc-b099-453d-a1d1-11a60bc724e4":{"compType":"BACK_OFFICE_PAGE","compName":"mobile-app.pages.settings","aiContext":{"description":"Purpose: Settings page for the Wix Owner mobile app. Configure app-level options such as app name, icon, notifications, and publishing preferences for the site\'s branded mobile application. Use this to adjust mobile app configuration.\\nAlso known as: mobile app preferences, app settings."}},"c696eca6-7489-40ae-8c41-815cea571b53":{"compType":"BACK_OFFICE_PAGE","compName":"member-permissions","aiContext":{"description":"Purpose: Member Permissions page \u2014 the main page for managing site member roles and permissions. Users view all roles, create custom roles, and control what members can access on the site.\\nAlso known as: member roles, site member permissions, roles and permissions, access control."}},"4db206f2-4b11-410c-a343-4cb09f0e9a22":{"compType":"BACK_OFFICE_PAGE","compName":"analytics-bookings-bm.pages.overviews.bookings","aiContext":{"description":"Purpose: Bookings analytics overview page. Aggregates booking performance metrics \u2014 sessions booked, revenue, top services, cancellation rates \u2014 in one report.\\nAlso known as: booking stats, appointment analytics, bookings performance, scheduling insights. Related: bookings list, services list."}},"6f97cfc6-0be0-4741-86c3-cc23ba53fa74":{"compType":"BACK_OFFICE_PAGE","compName":"Business Manager","aiContext":{"description":"Purpose: Business Manager home \u2014 the top-level back-office dashboard for a Wix site in the Business Manager workspace. Entry point for navigating to all management sections: analytics, marketing, store, bookings, CRM, and settings.\\nAlso known as: dashboard, home, back office, admin panel, site management, control panel."}},"c8e05f7f-48e9-4a92-8611-ae3e65d60219":{"compType":"BACK_OFFICE_PAGE","compName":"events-staff-page","aiContext":{"description":"Purpose: Events staff / team page. Manage staff members associated with Wix Events \u2014 add team members, assign roles, and control who can manage events in the back office.\\nAlso known as: staff, event staff, team members, event team."}},"c982ddd3-1521-4860-86fe-c9f24c535493":{"compType":"BACK_OFFICE_PAGE","compName":"c696eca6-7489-40ae-8c41-815cea571b53-alias-member-permissions-members","aiContext":{"description":"Purpose: Member Permissions \u2014 Members tab, where the user views and manages the list of site members, their status, and assigned roles. Use this to browse members, search for a specific member, or change a member\'s role. Distinct from the Roles tab (role definitions) and Settings tab (general permissions config).\\nAlso known as: members list, site members, manage members, member accounts."}},"e6576ec0-802c-4816-a84e-a206a10e7b3d":{"compType":"BACK_OFFICE_PAGE","compName":"automations-customer-notifications","aiContext":{"description":"Purpose: Automations Customer Notifications page \u2014 manages automated notification messages sent to customers (e.g., booking confirmations, order updates, abandoned cart reminders). Users view, enable/disable, or customize notification automations specifically aimed at customers.\\nAlso known as: customer emails, transactional notifications, automated emails, notification templates."}},"53d0bdd6-e587-43b5-bfe2-6abcc9be6ada":{"compType":"BACK_OFFICE_PAGE","compName":"wix-emails-module-pages-recipients","aiContext":{"description":"Purpose: Email campaign recipients page listing the audience targeted by an email campaign. Users view, filter, and manage the contact segments or mailing lists chosen for a campaign.\\nAlso known as: email recipients, who received email, campaign audience, mailing list for campaign, email contacts list."}},"e8960d54-12c9-4649-a89e-a5a6b38ca93c":{"compType":"BACK_OFFICE_PAGE","compName":"atlantic.pages.settings","aiContext":{"description":"Purpose: Multilingual (Atlantic) settings page \u2014 configuration options for the language menu widget, auto-translation preferences, SEO per-language settings, and translation source defaults. Users adjust how the language switcher looks and how automatic translation behaves. Distinct from the manage-languages page which controls the language list itself.\\nAlso known as: translation settings, multilingual config, language switcher settings."}},"28bb5f79-30c1-4a82-a40c-d11604c67ce9":{"compType":"BACK_OFFICE_PAGE","compName":"analytics-blog-bm.pages.overviews.blog","aiContext":{"description":"Purpose: Blog analytics overview page. Aggregates blog performance metrics \u2014 post views, reader engagement, top posts, posts performance on google search, blog traffic sources \u2014 in one report.\\nAlso known as: blog stats, blog performance, blog insights, post traffic. Related: blog posts list, site analytics."}},"5da7cc0e-93e2-49cf-b8fa-de46be1af7b7":{"compType":"BACK_OFFICE_PAGE","compName":"music-manager.my-albums","aiContext":{"description":"Purpose: Music Manager albums list. Displays all music albums the user has created or uploaded through the Wix Music app. Use this to add, edit, reorder, or delete albums and manage track listings.\\nAlso known as: my albums, music library, Wix Music, album list."}},"7226a5ff-4931-4183-966b-36c91c2a8d5e":{"compType":"BACK_OFFICE_PAGE","compName":"ecom-dashboard-tax-pages-rule-id","aiContext":{"description":"Purpose: Tax Rule detail/edit page for a single tax rule in Wix eCommerce. Users view and configure one tax rule \u2014 jurisdiction, rate, and applicable products \u2014 within the store\'s tax settings. Distinct from the tax rules list.\\nAlso known as: edit tax rule, tax rule settings, configure tax, tax rate.\\nDeep link: set `relativeUrl` to `{id}` \u2014 the tax rule id. Omit to open the default view."}},"92d5c9de-c8b2-4af3-8c83-03548814b5f6":{"compType":"BACK_OFFICE_PAGE","compName":"ai-visibility","aiContext":{"description":"Purpose: AI visibility overview page. Shows how the site appears across AI-powered search engines and chatbots (ChatGPT, Perplexity, Gemini); users see scan results, visibility scores, and recommendations to improve AI discoverability.\\nAlso known as: AI search visibility, AI SEO, chatbot presence, AI discovery, LLM search."}},"39464a12-cec7-4bb3-9ce9-c287a0ae2f02":{"compType":"BACK_OFFICE_PAGE","compName":"menu.store.orders.abandonedCarts","aiContext":{"description":"Purpose: Abandoned carts page in the Wix Stores order management section. Shows a list of checkout sessions that were started but not completed, with visitor details and cart contents. Use this to recover lost sales, send recovery emails, or review drop-off patterns.\\nAlso known as: abandoned checkouts, cart recovery, incomplete orders."}},"e9a62ec4-dcf0-41ac-8483-541bfcf82b61":{"compType":"BACK_OFFICE_PAGE","compName":"shub-explore-products.pages.marketplace","aiContext":{"description":"Purpose: Wix App Market / Marketplace explorer embedded in the Business Manager dashboard. Users browse, search, and install third-party and Wix-built apps for their site.\\nAlso known as: app market, app store, add apps, explore apps, find plugins, marketplace, extensions.\\nDeep link: set `relativeUrl` to `{productId}` \u2014 an external Print-on-Demand (Printful) product id string, not a Wix GUID. Omit to open the default view."}},"e359a8e4-063c-4a5f-93c9-bfacd6168c02":{"compType":"BACK_OFFICE_PAGE","compName":"rnp-pages-manage-roles-business-manager","aiContext":{"description":"Purpose: Manage roles page within Roles & Permissions (RNP) in Business Manager. Shows the full list of available roles and what each role can do, and lets you create or edit custom roles. Users come here to review role definitions, adjust what each role can do, or create a new custom role.\\nAlso known as: roles list, edit roles, custom roles, role permissions."}},"ac79f296-b30c-4f92-a937-fff2e0bc61be":{"compType":"BACK_OFFICE_PAGE","compName":"wix-code-secrets-manager-v-2.pages.index","aiContext":{"description":"Purpose: Secrets Manager page for Wix Code (Velo) sites in Business Manager. Lets users securely store API keys, passwords, and other sensitive values under a name, then reference that name in their site\'s code instead of exposing the actual value.\\nAlso known as: secrets manager, API keys, secret values, private keys, passwords, credentials."}},"5fba1bbb-353e-49e6-8afc-86e6cb119830":{"compType":"BACK_OFFICE_PAGE","compName":"social-groups-dashboard.pages.edit-group","aiContext":{"description":"Purpose: Manage a single Wix group. Multi-tab workspace for one group: edit info (name, description, cover image, privacy and access), manage members (roles, removal, invites, join requests), moderate the feed (posts) and comments, view the activity journey, manage the group\'s tabs and events, organize post topics, and configure per-group settings (rules, member permissions, membership questions, AI spam protection, auto-posts).\\nAlso known as: edit group, manage group, group members, group feed, moderate group, group settings.\\nDeep link: set `relativeUrl` to the group id (a GUID) to open the group, e.g. `{groupId}`. Append a page-relative sub-path for a specific area: `{groupId}/members`, `{groupId}/members/requests`, `{groupId}/posts`, `{groupId}/comments`, `{groupId}/content` (tabs), `{groupId}/content/events`, `{groupId}/topics`, `{groupId}/settings`. Omit `relativeUrl` to open the default view."}},"38f4110d-7e11-4dc7-81f6-1cc7a6c33af5":{"compType":"BACK_OFFICE_PAGE","compName":"wix-emails-module-pages-overview-campaignid","aiContext":{"description":"Purpose: Campaign overview/detail page for a specific email campaign identified by its ID. Displays performance stats, delivery summary, open and click rates, and campaign metadata. Users review results and status of a sent or scheduled campaign.\\nAlso known as: campaign stats, email campaign report, campaign results, email details, campaign performance.\\nDeep link: set `relativeUrl` to `{campaignId}` \u2014 the GUID of the campaign to open; this page shows a single campaign\'s overview, so provide the id."}},"941f507f-d79b-4ee0-b1fd-8d9768704070":{"compType":"BACK_OFFICE_PAGE","compName":"wixstores-dashboard-product-list.components.copy-product","aiContext":{"description":"Purpose: Wix Stores copy-product dialog or flow. Duplicate an existing product to create a new one with the same details as a starting point. Triggered from the product list.\\nAlso known as: duplicate product, clone product, copy product, make a copy."}},"ce9562b2-f279-4c45-bee8-af3870d27069":{"compType":"BACK_OFFICE_PAGE","compName":"membership-settings-lazy-component","aiContext":{"description":"Purpose: Pricing Plans Settings page \u2014 configuration options for the Wix Pricing Plans (Memberships) feature. Users set payment methods, cancellation policies, customer notifications, and other plan-level settings.\\nAlso known as: membership settings, pricing plan settings, subscription settings. Distinct from the plans list page."}},"dbf8d362-dfc3-4503-bb1c-d6e70f4651b9":{"compType":"BACK_OFFICE_PAGE","compName":"bookings-bookflow-settings-page","aiContext":{"description":"Purpose: Wix Bookings booking flow settings page. Configure how customers move through the online booking experience \u2014 step order, date/time selection behavior, buffer times, and confirmation options. Use this to adjust the booking funnel, checkout steps, or appointment scheduling flow. Siblings: general Bookings settings, checkout form settings."}},"da634417-9a38-4002-9920-5e9ba3e8acfe":{"compType":"BACK_OFFICE_PAGE","compName":"dashboard","aiContext":{"description":"Purpose: The main Business Manager Dashboard \u2014 the home/overview page for a Wix business site. Users see at-a-glance KPIs, recent activity, quick-access shortcuts, and site health. First page after logging in.\\nAlso known as: dashboard, home, overview, home page, main page."}},"c7ae31e0-aaf6-45cf-89ef-2460f67973a1":{"compType":"BACK_OFFICE_PAGE","compName":"subscriptions-bm-settings","aiContext":{"description":"Purpose: Subscriptions settings page in Business Manager. Users configure subscription-related settings such as payment terms, cancellation policies, and notification preferences for their site\'s subscription plans. Distinct from the subscriber list \u2014 this is the configuration panel.\\nAlso known as: subscription settings, recurring plan settings, subscription configuration."}},"9b111e6f-76c4-48e9-89cb-99e804ce6d31":{"compType":"BACK_OFFICE_PAGE","compName":"wix-code-triggered-emails.pages.index","aiContext":{"description":"Purpose: Triggered (transactional) emails page for Wix Code (Velo) sites. Lets users create, edit, preview, and view analytics for email templates that get sent automatically in response to actions defined in the site\'s code, such as welcome emails, order confirmations, or abandoned-cart follow-ups.\\nAlso known as: triggered emails, transactional emails, shoutout, automated emails, welcome email, abandoned cart email, thank you email."}},"f2b598a2-29cf-4f3d-9b11-6be5814c9a03":{"compType":"BACK_OFFICE_PAGE","compName":"discount-rules.pages.new-rule","aiContext":{"description":"Purpose: The New Discount Rule creation form for Wix eCommerce. Users define a new automatic discount rule: set conditions (minimum order, product criteria), discount type/value, and applicability. Distinct from the list page (which shows existing rules) and the edit page (for an existing rule).\\nAlso known as: create discount rule, new discount, add discount rule."}},"0f410434-052f-4edb-8a89-ef564e4465e5":{"compType":"BACK_OFFICE_PAGE","compName":"contacts-segments-page","aiContext":{"description":"Purpose: The Segments page within the Wix CRM Contacts section. Users create and manage contact segments \u2014 dynamic or static groups filtered by contact properties, activity, or labels \u2014 to target specific audiences.\\nAlso known as: contact segments, contact groups, audience segments, filter contacts."}},"0e9958cd-3ce5-4643-86bc-541c08a2a2c3":{"compType":"BACK_OFFICE_PAGE","compName":"file-share-dashboard-bm.pages.index","aiContext":{"description":"Purpose: File share / member file-sharing dashboard. Manage files shared with site members \u2014 upload, organize, and control access to downloadable files.\\nAlso known as: file sharing, member files, file library, shared files, document sharing."}},"ac9daeae-e49d-47c3-b592-c539bf85e473":{"compType":"BACK_OFFICE_PAGE","compName":"stores-channels-google.pages.index","aiContext":{"description":"Purpose: Wix Stores Google channel integration page. Users connect their product catalog to Google Shopping / Google Merchant Center, configure sync settings, and monitor listing status.\\nAlso known as: Google Shopping, Google Merchant Center, Google product feed, stores Google channel, sync products to Google."}},"ecda390d-3a87-4eff-a7a7-fab8dce21985":{"compType":"BACK_OFFICE_PAGE","compName":"826670ba-3a6b-4157-ac72-7c4fca9ce220-dashboard.1c5b7dec-159e-48cf-b618-6d77d7a17f8c|2","aiContext":{"description":"Purpose: Wix Hotels room types management page. Lists all room categories (e.g. Standard, Suite); users create, edit, or delete room types, configure capacity, amenities, and photos.\\nAlso known as: room categories, room catalog, accommodation types, room setup. Related: room rates, extras."}},"02808703-cdf0-4025-b6e5-71e2de478653":{"compType":"BACK_OFFICE_PAGE","compName":"bookings-calendar-page-platform-lazy-component-id","aiContext":{"description":"Purpose: Wix Bookings calendar page (platform variant). Visual calendar agenda for appointments and staff availability, loaded via the platform component path. Same purpose as the standard calendar \u2014 day/week/month schedule view, manage bookings, block time, manual appointments. Use when the standard calendar component is unavailable or for platform-specific routing."}},"440f7929-c3ea-45cf-b3a9-37a2b3631b7c":{"compType":"BACK_OFFICE_PAGE","compName":"bookings-policies-list","aiContext":{"description":"Purpose: Wix Bookings cancellation and booking policies list. View all defined policies (cancellation windows, no-show fees, rescheduling rules) applied across services. Add new policies or select one to edit. Distinct from the individual policy editor.\\nAlso known as: policies, cancellation rules, booking terms."}},"1f26dd3d-6d37-4caa-ba25-0b1e9e46e664":{"compType":"BACK_OFFICE_PAGE","compName":"wix-emails-module-pages-analytics-campaignid","aiContext":{"description":"Purpose: Email campaign analytics page (per campaignId) in the Wix Emails module. Users review performance stats for a specific sent campaign \u2014 open rate, click rate, bounces, unsubscribes, and revenue.\\nAlso known as: email analytics, campaign stats, email report, campaign performance, email metrics.\\nDeep link: set `relativeUrl` to `{campaignId}` \u2014 the GUID of the campaign to open; this page shows a single campaign\'s analytics, so provide the id."}},"696055d1-1def-4c90-8dd8-7ed398cc3649":{"compType":"BACK_OFFICE_PAGE","compName":"olo-settings-pickup-delivery","aiContext":{"description":"Purpose: Online Ordering pickup and delivery settings. Configure fulfillment options for restaurant online ordering \u2014 enable/disable pickup, set delivery zones, minimum order amounts, fees, and estimated times. Use this to manage how customers receive their orders.\\nAlso known as: delivery settings, pickup settings, fulfillment settings, OLO delivery."}},"20b230c4-8453-4a4b-9a4f-c1758c1785a9":{"compType":"BACK_OFFICE_PAGE","compName":"wix-emails-module-pages-preview-campaignid","aiContext":{"description":"Purpose: Preview page for a specific email campaign, showing the rendered email as recipients see it. Users inspect the email design, content, and layout before sending or after sending for review.\\nAlso known as: email preview, preview campaign, view email, how will email look, email render.\\nDeep link: set `relativeUrl` to `{campaignId}` \u2014 the GUID of the campaign to open; this page shows a single campaign\'s preview, so provide the id."}},"44b09839-c17a-4414-b619-f728a01f5377":{"compType":"BACK_OFFICE_PAGE","compName":"pricing-plans.pages.custom-forms-composer","aiContext":{"description":"Purpose: Custom forms composer for Pricing Plans. Users build or edit a custom intake/checkout form that members fill in when purchasing a pricing plan.\\nAlso known as: pricing plan form, custom checkout form, plan intake form, form builder pricing plans, membership form editor."}},"15a20016-bec1-4737-a764-6f5b3391e3c7":{"compType":"BACK_OFFICE_PAGE","compName":"bookings-addons-list","aiContext":{"description":"Purpose: Bookings Add-ons list page. Shows the add-ons (upsells offered during booking checkout, e.g., equipment rental, extras) defined for the business. Users create, edit, enable/disable, and delete add-ons.\\nAlso known as: booking extras, upsells, service add-ons, checkout extras."}},"c7fbb124-2acd-4db2-8142-0ec7e220c266":{"compType":"BACK_OFFICE_PAGE","compName":"wix-emails-module-pages-ai-edit","aiContext":{"description":"Purpose: AI-assisted email editing page within the Wix Emails module. Users leverage AI to generate or refine email content (subject lines, body copy) for a campaign.\\nAlso known as: AI email editor, AI write email, generate email with AI, AI campaign editor, smart email editor.\\nDeep link: set `relativeUrl` to `{campaignId}` \u2014 a required campaign GUID. Do not omit it: this page needs a valid campaign id and has no default view."}},"91830018-1244-4006-9e72-b2c1bc694b24":{"compType":"BACK_OFFICE_PAGE","compName":"automations-builder.pages.activity-logs.index","aiContext":{"description":"Purpose: Automations Activity Log page \u2014 historical record of automation executions. Users see which automations ran, when, for which contacts/triggers, and whether they succeeded or failed. Used for debugging and auditing automation behavior.\\nAlso known as: automation history, automation run log, automation audit log.\\nDeep link: set `relativeUrl` to `{idx}` \u2014 a GUID (automation entity id; idx is passed as automationId). Omit to open the default view."}},"9728c715-8b64-4d9b-b5a6-a33c201ce8e6":{"compType":"BACK_OFFICE_PAGE","compName":"bookings-policy-form-pages-policyid","aiContext":{"description":"Purpose: Wix Bookings policy editor \u2014 create or edit a single cancellation/booking policy. Set the cancellation window, late-cancellation fee, no-show penalty, and rescheduling rules for a specific policy. Accessed via a policy ID in the URL. Sibling: policies list page where all policies are managed.\\nDeep link: set `relativeUrl` to `{policyId}` \u2014 a GUID (the bookings policy id). Omit to open the default view."}},"70bb69f6-59db-46b1-857e-83322f2094dd":{"compType":"BACK_OFFICE_PAGE","compName":"826670ba-3a6b-4157-ac72-7c4fca9ce220-dashboard.1c5b7dec-159e-48cf-b618-6d77d7a17f8c|0","aiContext":{"description":"Purpose: Wix Hotels dashboard overview page. High-level summary of hotel performance \u2014 occupancy, revenue, upcoming check-ins \u2014 giving a snapshot of the property at a glance.\\nAlso known as: hotel home, hotel summary, hotel dashboard, accommodation overview. Related: room types, property settings."}},"1267f596-4033-401d-b4af-59e05c52253f":{"compType":"BACK_OFFICE_PAGE","compName":"wix-emails-module-pages-my-campaigns","aiContext":{"description":"Purpose: My Campaigns list page in the Wix Emails module. Users browse all their email campaigns (sent, draft, scheduled) with statuses and quick links to edit, duplicate, or view stats.\\nAlso known as: my campaigns, all campaigns, email campaigns list, campaign history, newsletters list."}},"f2526550-194f-4c13-9298-9a6b8abda62f":{"compType":"BACK_OFFICE_PAGE","compName":"ecom-platform-dashboard-orders-draft.order-edit-page","aiContext":{"description":"Purpose: Edit-order page \u2014 edit an existing order via the same draft-order mechanism and UI as the create-order page (only the CTA/behavior differs). Add or remove line items (from catalogs or custom), change price and quantity, add fees and discounts, set the delivery method, and update the contact associated with the order.\\nAlso known as: edit order, modify order, change order, update order items.\\nDeep link: set `relativeUrl` to `{orderId}` \u2014 a GUID (the id of the order to edit)."}},"bb157e9f-79ba-409e-825c-325bacf702f3":{"compType":"BACK_OFFICE_PAGE","compName":"form-app-bm.pages.standalone-form","aiContext":{"description":"Purpose: Standalone form page in the Wix Forms back-office app, used to view or manage a form that exists independently outside the main forms list (e.g. embedded or linked directly).\\nAlso known as: standalone form, single form, direct form link.\\nDeep link: set `relativeUrl` to `{formId}` or `{formId}/{tab}` or `{formId}/{tab}/{scrollTarget}` \u2014 formId is an optional form GUID, tab an optional tab name, scrollTarget an optional scroll target. All segments are optional; with none, the page opens its default view with no form loaded."}},"e83f8925-8495-44d9-876c-a7bb3b57a99a":{"compType":"BACK_OFFICE_PAGE","compName":"event-occurrences","aiContext":{"description":"Purpose: Event occurrences page for a recurring Wix Event. Lists all scheduled instances (dates/times) of a repeating event and lets users manage individual occurrences \u2014 edit, cancel, or view registrations per occurrence.\\nAlso known as: recurring event dates, event schedule, event instances, occurrences.\\nDeep link: set `relativeUrl` to `{categoryId}` \u2014 the recurring event\'s category GUID. Omit to open the default view."}},"978a178c-a739-46ed-93c3-60afaabd6ca4":{"compType":"BACK_OFFICE_PAGE","compName":"loyalty-bm-pages-manage","aiContext":{"description":"Purpose: Loyalty Program management page \u2014 the main operational hub for running a Wix Loyalty program. Users configure point-earning rules, rewards, tiers, and member activity from here.\\nAlso known as: manage loyalty, loyalty rewards settings, points program management. Distinct from the welcome/onboarding page and the overview landing page."}},"6b457a54-c141-4bf8-bd49-3d6470bec250":{"compType":"BACK_OFFICE_PAGE","compName":"seating-page","aiContext":{"description":"Purpose: Seating map / seating plan management page for Wix Restaurants or Events. Lets the owner create and configure the venue\'s seating layout \u2014 tables, sections, and capacity. Users come here to set up or edit a seating chart, define table arrangements, or manage venue capacity.\\nAlso known as: seating chart, seating layout, venue map, table management, floor plan.\\nDeep link: set `relativeUrl` to `{planId}` \u2014 a GUID (seating plan entity .id). Omit to open the default view."}},"b971a208-0d17-4831-86be-d00e51f49e1b":{"compType":"BACK_OFFICE_PAGE","compName":"discount-rules.pages.rule.id","aiContext":{"description":"Purpose: The Discount Rule detail/edit page for a specific existing rule in Wix eCommerce. Users view and edit all settings of an already-created automatic discount rule. Distinct from the new-rule form and the list page.\\nAlso known as: edit discount rule, discount rule settings, update discount.\\nDeep link: set `relativeUrl` to `{ruleId}` \u2014 a GUID (discount rule id; consumed as discountRuleId, maps to discountRule.id). Omit to open the default view."}},"1a0a78bd-9d05-46b9-bafe-504bdcac65ee":{"compType":"BACK_OFFICE_PAGE","compName":"bookings-manage-participants-pages-manage-participants","aiContext":{"description":"Purpose: Wix Bookings manage participants page for a specific session or class. View and edit the attendee list for a group session \u2014 add or remove participants, mark attendance, manage waitlists, and handle participant-level actions like refunds or rescheduling. Used for classes and group events, not individual appointments."}},"c3705c08-8cea-4b7c-946c-5b838556eeab":{"compType":"BACK_OFFICE_PAGE","compName":"PRICING_PLANS.pages.new-order","aiContext":{"description":"Purpose: New order page within the Pricing Plans section. Users manually create a new subscription order for a client \u2014 selecting plan, member, and billing details.\\nAlso known as: new pricing plan order, create order, add subscription order, manual plan order, new membership order."}},"72aaa392-4240-43cc-9d9a-f6df2899cb16":{"compType":"BACK_OFFICE_PAGE","compName":"826670ba-3a6b-4157-ac72-7c4fca9ce220-dashboard.1a6e0874-2039-49cf-bef3-9138bb5c3b16|0","aiContext":{"description":"Purpose: Wix Hotels reservations list page. Shows all incoming and past hotel room reservations; users view reservation details, filter by date or status, and manage bookings.\\nAlso known as: hotel bookings, room reservations, guest stays, accommodation orders. Related: reservation calendar, inventory calendar."}},"b54036bb-ccc7-419d-a017-bdfc1b821643":{"compType":"BACK_OFFICE_PAGE","compName":"crm-automations-approvals","aiContext":{"description":"Purpose: Automation Approvals page in Business Manager \u2014 a sub-page of Wix Automations that lists approval items produced by automation workflows for the user to review. Reached from the Automations area (breadcrumb: Automations \u203a Approvals); distinct from the main automations list and the single-automation editor.\\nAlso known as: automation approvals, approvals, pending approvals, approval requests, automations approvals."}},"421505c4-66e0-40d2-88ea-f222d2a0d36b":{"compType":"BACK_OFFICE_PAGE","compName":"social-groups-dashboard.pages.create-group","aiContext":{"description":"Purpose: Create-group page for Wix Groups. A form to add a new community group \u2014 set its name, description, cover image, and privacy type (public, private, or hidden). Can be pre-filled from a group template. Reached from the Groups dashboard via \\"Create Group\\".\\nAlso known as: create group, add group, new group, start a group, make a group."}},"958cdd9c-07e7-4475-9d7f-f2efe272d610":{"compType":"BACK_OFFICE_PAGE","compName":"social-groups-dashboard.pages.pending-groups","aiContext":{"description":"Purpose: Group requests page for Wix Groups. Lists pending group-creation requests submitted by site members when new groups require admin approval before going live. Approve or reject each requested group here.\\nAlso known as: group requests, pending groups, approve groups, group creation requests, groups awaiting approval."}},"f2982b03-0b99-49c8-9387-9dd048df52b7":{"compType":"BACK_OFFICE_PAGE","compName":"social-groups-dashboard.pages.member-requests","aiContext":{"description":"Purpose: Member requests page for Wix Groups. Central list of pending join requests from people asking to become members of private groups across the site. Approve or decline membership requests here.\\nAlso known as: member requests, join requests, membership requests, pending members, approve members."}},"5b525730-254f-4581-86f7-1efbfa7698f9":{"compType":"BACK_OFFICE_PAGE","compName":"social-groups-dashboard.pages.post","aiContext":{"description":"Purpose: Post editor for Wix Groups. Full-screen composer to create or edit a post in a group\'s feed: write rich content, add media, assign topics, schedule publishing, save as a draft, and set monetization (members-only/paid). Reached when creating or editing a group post.\\nAlso known as: create post, edit post, write post, group post, compose post, schedule post, post editor."}},"6998e473-e66d-468a-9467-edd96967b051":{"compType":"BACK_OFFICE_PAGE","compName":"social-groups-dashboard.pages.settings","aiContext":{"description":"Purpose: Groups app settings in Business Manager \u2014 site-wide settings for the whole Groups app, not a single group. Control who can create groups and whether new groups need approval, configure the members\' weekly digest email, and manage automated group notifications. To change settings for one specific group, use that group\'s own Settings tab instead.\\nAlso known as: groups app settings, app settings, who can create groups, weekly digest, group notifications."}},"a882328f-d38f-434d-9d83-2a610eef4c2c":{"compType":"BACK_OFFICE_PAGE","compName":"social-groups-dashboard.pages.templates","aiContext":{"description":"Purpose: Group templates gallery for Wix Groups. Browse ready-made group templates to start a new group quickly, or create a group with the AI assistant. Selecting a template opens the Create Group form pre-filled from it.\\nAlso known as: group templates, templates, group ideas, start from template, create group with AI."}},"4df593f9-81a2-4c1e-b383-2dc11320dd2d":{"compType":"BACK_OFFICE_PAGE","compName":"challenges-web-business-manager-categories","aiContext":{"description":"Purpose: Program categories for Wix Online Programs (formerly Challenges) \u2014 organize online programs into categories so site visitors can browse related courses and programs together. Create, rename, and delete categories, and assign programs to each category. Use this to manage how programs are grouped and browsed on the site.\\nAlso known as: program categories, categories, course categories, organize programs, group programs, manage categories."}}}'),vte=JSON.parse('{"1e54454f-8546-4aae-82fc-b3b16921cb18":{"compType":"BACK_OFFICE_PAGE","compName":"Sites List o/ Studio","aiContext":{"description":"Purpose: Sites List page in the Wix Studio workspace, showing all sites the agency or user manages. Users view, search, and open individual client or personal sites from this central hub.\\nAlso known as: all sites, site overview, site list, dashboard home, portfolio of sites, my sites (Studio)."}},"e6e62f46-e27e-4a8f-bbd0-ef9365b94c16":{"compType":"BACK_OFFICE_PAGE","compName":"wix-studio-discover","aiContext":{"description":"Purpose: Wix Studio Discover page \u2014 a curated hub for exploring new Studio features, resources, inspiration, and announcements. Users browse highlights, tutorials, and platform updates relevant to Studio partners.\\nAlso known as: studio discover, explore studio, studio news, what\'s new in studio, studio highlights."}},"a4544a9e-8506-43b8-aec8-8ed38be76c2e":{"compType":"BACK_OFFICE_PAGE","compName":"studio-cairo-subscriptions","aiContext":{"description":"Purpose: Studio subscriptions page backed by Wix\'s Cairo billing platform (studio-cairo-subscriptions). Users view, manage, and upgrade their active Studio subscription plans and billing cycles.\\nAlso known as: Studio plan, subscription billing, upgrade Studio, Studio pricing, cairo subscriptions, manage plan."}},"29e943c6-a17e-487d-bcee-4967332752e8":{"compType":"BACK_OFFICE_PAGE","compName":"workspace-settings","aiContext":{"description":"Purpose: Wix Studio workspace settings page. Configure settings for the Studio workspace \u2014 manage workspace name, branding, member permissions, billing, and other workspace-level preferences.\\nAlso known as: workspace preferences, studio settings, agency settings, workspace configuration, workspace admin."}},"04b7df46-f12a-497e-91f8-69f4c89d28af":{"compType":"BACK_OFFICE_PAGE","compName":"studio-domains","aiContext":{"description":"Purpose: Domain management page in Wix Studio. Users connect, transfer, purchase, or release custom domains for Studio sites, manage DNS records, and set primary domains.\\nAlso known as: Studio domains, connect domain, custom domain, DNS settings, domain management."}},"5b817f81-4c77-4594-9075-2dbac30b52f0":{"compType":"BACK_OFFICE_PAGE","compName":"wix-studio-custom-templates","aiContext":{"description":"Purpose: Wix Studio custom templates management page where agency partners create, manage, and organize their proprietary site templates. Users add new templates, edit existing ones, and control which are available to clients.\\nAlso known as: custom templates, agency templates, studio templates, my templates, partner templates."}},"0cdf8fa1-742c-42c0-b2dc-0bb93ebced87":{"compType":"BACK_OFFICE_PAGE","compName":"billing-history-studio","aiContext":{"description":"Purpose: Billing History page for Wix Studio workspace. Shows past invoices, charges, and payment records for Studio subscriptions and plan purchases. Users download invoices, review charges, and track billing activity. Studio-workspace variant \u2014 distinct from the standard Business Manager billing history.\\nAlso known as: invoices, payment history, Studio billing, charges."}},"311b4868-78bb-4807-9793-0d41c6bc61d9":{"compType":"BACK_OFFICE_PAGE","compName":"branded-apps-studio-business-manager","aiContext":{"description":"Purpose: Branded Apps page in Wix Studio back-office where the user manages their branded mobile app \u2014 configuring app name, icon, colors, and publishing settings. Use this to launch, update, or review a white-label mobile app built on Wix.\\nAlso known as: mobile app, branded app, app builder, publish app, app settings."}},"5f4025e3-3f5c-4cdd-ae84-8bb5fa50f219":{"compType":"BACK_OFFICE_PAGE","compName":"studio-mailboxes","aiContext":{"description":"Purpose: Professional mailbox management page in Wix Studio. Users purchase, set up, and manage branded email addresses (e.g. name@yourdomain.com) linked to Studio sites.\\nAlso known as: Studio mailboxes, professional email, business email, email hosting, mailbox settings."}},"ba752dde-ebde-45fc-bb1c-30f2a70aafff":{"compType":"BACK_OFFICE_PAGE","compName":"Custom Apps o/ Studio","aiContext":{"description":"Purpose: The Custom Apps page in Wix Studio back-office. Users browse, install, manage, and configure third-party or custom-built apps added to their Studio workspace.\\nAlso known as: custom apps, installed apps, Studio apps, app management."}},"8246caf4-582e-4ad1-a721-422a6c0ff55c":{"compType":"BACK_OFFICE_PAGE","compName":"studio-team","aiContext":{"description":"Purpose: Team management page for a Wix Studio workspace. Lets the workspace owner invite collaborators, assign roles and permissions, remove members, and view pending invitations.\\nAlso known as: Studio team, invite collaborators, team members, workspace members, manage team, permissions."}},"09bba39a-41d4-4ac3-9ec6-e17bf8392c08":{"compType":"BACK_OFFICE_PAGE","compName":"payment-methods-studio","aiContext":{"description":"Purpose: Payment methods settings page in Wix Studio. Configure which payment providers and methods are accepted on the site \u2014 credit cards, PayPal, offline payments, etc. Use this to connect a payment provider, add or remove payment options, or review payment gateway settings.\\nAlso known as: payment providers, payment settings, checkout payments, Studio payments."}},"20333a40-7442-41a4-b21d-f12207637744":{"compType":"BACK_OFFICE_PAGE","compName":"wix-studio-feedback-dashboard","aiContext":{"description":"Purpose: Wix Studio feedback dashboard where agency partners view and manage feedback submitted by their clients. Users track client comments, ratings, or satisfaction signals about delivered work.\\nAlso known as: client feedback, feedback dashboard, client reviews, studio feedback, agency client feedback."}},"423f5ca7-c9cf-48fc-b6ea-4ac8d6d8877e":{"compType":"BACK_OFFICE_PAGE","compName":"business-info-over-studio","aiContext":{"description":"Purpose: Business Info settings page (Wix Studio workspace) where the user manages their business\'s public details \u2014 name, address, phone, email, business hours, and category. Use this to update contact information displayed to customers.\\nAlso known as: business details, company info, store info, business profile, location settings."}},"c4820915-5883-4866-998c-8b0870d713ef":{"compType":"BACK_OFFICE_PAGE","compName":"wix-studio-revenues-overview","aiContext":{"description":"Purpose: Wix Studio revenues overview page providing a consolidated financial summary for Studio partners, including income sources, trends, and totals. Distinct from the top-level revenues page \u2014 this is the detailed overview tab.\\nAlso known as: revenue overview, financial overview, studio earnings summary, income overview, studio revenue dashboard."}},"08cefa61-5f37-4eda-8e07-3dc9efe9752f":{"compType":"BACK_OFFICE_PAGE","compName":"partner-tickets.pages.index","aiContext":{"description":"Purpose: Partner tickets page in Wix Studio. Lets Studio partners (agencies, freelancers) submit and track support tickets with Wix. Use this to open a new support case, view existing ticket status, or follow up on partner-level issues.\\nAlso known as: support tickets, partner support, help tickets, Studio support."}},"f08b4e71-dd5f-4564-859b-ef366af5b76c":{"compType":"BACK_OFFICE_PAGE","compName":"wix-studio-studio-templates","aiContext":{"description":"Purpose: Wix Studio template library \u2014 your own studio\'s templates. Browse, manage, and publish templates you (or your studio) have created for use within Wix Studio. Distinct from the public Wix template catalog.\\nAlso known as: my studio templates, custom templates, agency templates, our template collection."}},"571111c5-6dab-4275-9f58-54f2c5515a6e":{"compType":"BACK_OFFICE_PAGE","compName":"wix-studio-agency-profile.pages.index","aiContext":{"description":"Purpose: Wix Studio agency profile index page where a Studio agency manages their public-facing profile. Users edit agency details, portfolio, and information shown to potential clients in the Wix Studio marketplace.\\nAlso known as: agency profile, studio profile, my agency page, edit agency info, partner profile."}},"4ae30782-08af-45e5-9e9b-6f13fc818a48":{"compType":"BACK_OFFICE_PAGE","compName":"studio-vouchers","aiContext":{"description":"Purpose: Vouchers management page in Wix Studio. Users create, view, and manage discount voucher codes that can be offered to clients or applied to Studio services.\\nAlso known as: Studio vouchers, discount codes, coupon codes, promo codes, voucher management."}},"be1327f6-1ad5-4268-9179-7e72c0ceb7f0":{"compType":"BACK_OFFICE_PAGE","compName":"account-notifications-preferences.pages.index","aiContext":{"description":"Purpose: Wix Studio account notification preferences page. Controls which email and in-product notifications the account receives; users toggle alerts for publishing, comments, team activity, and billing events.\\nAlso known as: notification settings, email alerts, alert preferences, account alerts."}},"af0bd691-b734-47cc-8be2-d4b54edcf221":{"compType":"BACK_OFFICE_PAGE","compName":"wix-studio-revenues-invoice-history","aiContext":{"description":"Purpose: Wix Studio revenues \u2014 invoice history page listing all past invoices issued to clients by the Studio partner. Users review, download, and track historical billing records.\\nAlso known as: invoice history, past invoices, billing history, studio invoices, payment history, studio billing."}},"374b78d8-a5c5-4ff7-afac-915a25f23587":{"compType":"BACK_OFFICE_PAGE","compName":"wix-studio-revenues","aiContext":{"description":"Purpose: Wix Studio revenues summary page showing total earnings across all revenue streams for a Studio partner. Users get a top-level financial overview of income from clients, subscriptions, and other sources.\\nAlso known as: studio revenues, earnings, income, my revenue, studio financials, money earned."}},"15c26f79-62e6-4f4f-982e-258c24c7ff03":{"compType":"BACK_OFFICE_PAGE","compName":"studio-subscriptions","aiContext":{"description":"Purpose: Subscriptions management page in Wix Studio. Users view their recurring Studio service subscriptions, renew, cancel, or change plans. Distinct from site-member recurring plans \u2014 this covers workspace/service-level subscriptions.\\nAlso known as: Studio subscriptions, my subscriptions, manage subscriptions, recurring plans."}},"aa51591d-1085-4e17-8b4c-4ab3ec9e1b71":{"compType":"BACK_OFFICE_PAGE","compName":"Studio - Wix Payments Account for Owners","aiContext":{"description":"Purpose: Wix Payments account page for Studio site owners. Owners set up and manage their Wix Payments account, configure bank/payout details, complete KYC verification, and review account standing.\\nAlso known as: payments account, Wix Payments owner, set up payments, payout settings, payment account owner."}},"41a57462-2026-49fe-b0ef-63900fa2f092":{"compType":"BACK_OFFICE_PAGE","compName":"Studio - Wix Payments Account for Collaborators","aiContext":{"description":"Purpose: Wix Payments account page for Studio collaborators (non-owner role). Collaborators can view payment account status, see payout information, and access transaction history, with permissions scoped to the collaborator role.\\nAlso known as: payments account, Wix Payments collaborator, payment details, payouts."}},"6ebe7516-2ab5-407e-adae-cdf2b70dce15":{"compType":"BACK_OFFICE_PAGE","compName":"wix-studio-client-kit-account-page","aiContext":{"description":"Purpose: Wix Studio client kit account page for managing client-facing resources shared with agency clients. Users access and configure the kit of materials, assets, or onboarding content provided to their clients.\\nAlso known as: client kit, client resources, client account, studio client portal, client materials."}},"5ea050c5-5a12-45dc-a7c7-edd8d7df0c61":{"compType":"BACK_OFFICE_PAGE","compName":"wix-studio-wix-templates","aiContext":{"description":"Purpose: Wix platform template gallery within Wix Studio. Browse the full catalog of Wix-provided website templates to use as a starting point for new sites.\\nAlso known as: template picker, choose a template, Wix templates, website templates, start from template."}},"cb1e67c0-22c3-423f-9e68-4d1ca7b3fcd3":{"compType":"BACK_OFFICE_PAGE","compName":"studio-analytics","aiContext":{"description":"Purpose: Analytics dashboard for Wix Studio workspace. Shows traffic, visitor behaviour, revenue metrics, and performance trends across Studio sites. Users review reports, set date ranges, and drill into traffic sources or conversions.\\nAlso known as: Studio analytics, traffic report, site stats, performance metrics, visitor analytics."}},"91674ea5-dedf-4326-a52d-d72ac1aa667b":{"compType":"BACK_OFFICE_PAGE","compName":"wix-studio-custom-branding","aiContext":{"description":"Purpose: Wix Studio custom branding page where Studio partners configure branded white-label presentation for their agency or workspace. Users set logos, colors, and brand identity for client-facing experiences.\\nAlso known as: custom branding, white label, agency branding, brand settings, studio branding."}},"94ab9fb3-ead7-4a58-a57d-18027b0ba93e":{"compType":"BACK_OFFICE_PAGE","compName":"wix-studio-revenues-payment-method","aiContext":{"description":"Purpose: Wix Studio revenues payment method settings page. Manage how you receive payouts as a Studio partner \u2014 connect or update your bank account, PayPal, or other payment method. Use this to set up or change where your earnings are deposited.\\nAlso known as: payout method, bank details, withdrawal setup, how do I get paid."}},"035d25f4-07ea-4e3e-9500-251a820a04d9":{"compType":"BACK_OFFICE_PAGE","compName":"wix-studio-marketplace-empty-states","aiContext":{"description":"Purpose: Wix Studio Marketplace empty states management page \u2014 a utility/configuration surface for defining what users see when marketplace sections have no content. Likely an internal or partner-facing config page for empty state UI copy or visuals.\\nAlso known as: marketplace empty states, no content states, marketplace placeholder, empty marketplace."}},"2d48bd4e-909a-4692-a575-ad8e2e1cd0c1":{"compType":"BACK_OFFICE_PAGE","compName":"wix-studio-revenues-template-earnigns","aiContext":{"description":"Purpose: Wix Studio template earnings dashboard. View revenue earned from selling or publishing Wix Studio templates in the marketplace. Shows earnings history, per-template breakdown, and payout status.\\nAlso known as: template revenue, template income, how much have I earned from templates, template royalties."}},"512abd8e-6b7c-4f5c-9faa-de5a0216906b":{"compType":"BACK_OFFICE_PAGE","compName":"wix-studio-revenues-app-sales","aiContext":{"description":"Purpose: Wix Studio revenues \u2014 app sales breakdown page showing earnings specifically from app sales on the Wix marketplace. Users drill into revenue attributed to their published apps. Distinct from the revenues overview which covers all streams.\\nAlso known as: app sales revenue, app earnings, marketplace app income, app revenue breakdown."}},"cf0bfcd7-97dc-4fd3-ab3f-f5a59b808b00":{"compType":"BACK_OFFICE_PAGE","compName":"wix-studio-marketplace-overview","aiContext":{"description":"Purpose: Wix Studio Marketplace overview page giving Studio partners a summary of their marketplace presence, listings, and activity. Users see how their apps or services are performing in the marketplace at a glance.\\nAlso known as: marketplace overview, studio marketplace, app marketplace, marketplace summary, my marketplace."}},"1f39de6e-a729-4d59-a4d6-23d300b50227":{"compType":"BACK_OFFICE_PAGE","compName":"Webhooks Page in Studio","aiContext":{"description":"Purpose: Webhooks configuration page in Wix Studio. Developers add, edit, and delete webhook endpoints that receive real-time event notifications from the site (e.g. order created, form submitted).\\nAlso known as: Studio webhooks, webhook settings, event notifications, HTTP callbacks, webhook endpoints."}},"8bdc852a-b1c3-4514-b2dd-7af954221dcf":{"compType":"BACK_OFFICE_PAGE","compName":"rnp-pages-team-studio-dashboard","aiContext":{"description":"Purpose: Team management page within Roles & Permissions (RNP) in the Studio Dashboard workspace. Lists all team members with access to the Studio account and their roles, and lets you manage team access at the Studio level (not per-site). Users come here to manage Studio team members.\\nAlso known as: Studio team, team members, manage team, Studio team access."}},"961923f5-1339-4999-8375-6e9da95ab1d1":{"compType":"BACK_OFFICE_PAGE","compName":"Marketplace Overview","aiContext":{"description":"Purpose: Wix Studio Marketplace overview page \u2014 the main landing page for the Wix Partner Marketplace where Studio partners (agencies/freelancers) manage their marketplace presence. Shows summary stats, listing status, and navigation to profile and projects.\\nAlso known as: marketplace home, partner marketplace overview, studio marketplace dashboard."}},"6ad06f0e-f6cc-411b-ade5-28a88d1b17a1":{"compType":"BACK_OFFICE_PAGE","compName":"Marketplace Projects","aiContext":{"description":"Purpose: Wix Studio Marketplace Projects list page \u2014 shows all portfolio projects a partner has submitted or published to the Wix Marketplace. Users add new projects, reorder, edit, or remove existing ones.\\nAlso known as: marketplace projects, portfolio projects, case studies list. Sibling to the individual project detail page."}},"42782988-9563-4cd7-a252-52eaf55dacf3":{"compType":"BACK_OFFICE_PAGE","compName":"Marketplace Projects Details","aiContext":{"description":"Purpose: Wix Studio Marketplace Project Details page \u2014 view and edit a single portfolio project entry in the Wix Marketplace. Users update the project title, description, images, categories, and publish status.\\nAlso known as: project detail, edit marketplace project, portfolio entry. Sibling to the projects list page.\\nDeep link: set `relativeUrl` to `{projectId}` \u2014 a GUID (Wix Studio marketplace project id). Omit to open the default view."}},"2bcee8a9-337a-4c24-96ca-bbff42e0b458":{"compType":"BACK_OFFICE_PAGE","compName":"Marketplace Profile","aiContext":{"description":"Purpose: Wix Studio Marketplace Profile page \u2014 where partners view and edit their public marketplace profile (bio, logo, specialties, contact info). Users update the information displayed to potential clients browsing the marketplace.\\nAlso known as: marketplace profile, partner profile, agency profile, edit studio profile."}}}');let Nte;const Ote=()=>Nte??={..._te,...vte},Tte="h